# Mesh Graph Descriptor for the 2->2 GRPO BoolQ training example.
#
# Two [1, 2] meshes (one per MPI rank), each covering ONE N300 board (two
# chips):
#   * Rank 0 (TTML, GRPOTrainer driver + WeightBridge sender) -> mesh_id 0,
#     a [1, 2] DDP mesh.
#   * Rank 1 (TTT,  WeightBridge receiver) -> mesh_id 1, a [1, 2] parent mesh
#     that the example splits into two [1, 1] submeshes.
# The FABRIC graph wires the two meshes together so the cross-rank
# handshake/transport can route across them. This is the smaller sibling of
# configurations/local8/mgd.textproto (the 4->4 split); the Python example
# logic is hardware-agnostic and does not depend on these exact values.
#
# !!! HARDWARE-SPECIFIC TEMPLATE !!!
# This declares a [1, 2] line per rank spanning the two chips of one N300
# board. Each board is one PCIe device with two chips reachable to UMD via the
# on-board eth link. The full physical eth topology must be declared here or
# ControlPlane::init_control_plane() trips `Fabric node ID not yet assigned for
# ASIC id ...`. Adjust this file (and rank_bindings.yaml) for your machine.

mesh_descriptors {
  name: "M0"
  arch: WORMHOLE_B0
  device_topology { dims: [ 1, 2 ] }
  host_topology   { dims: [ 1, 1 ] }
  channels {
    count: 2
    policy: RELAXED
  }
}

graph_descriptors {
  name: "G0"
  type: "FABRIC"
  instances { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
  instances { mesh { mesh_descriptor: "M0" mesh_id: 1 } }

  connections {
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 1 } }
    channels { count: 2 }
  }
}

top_level_instance { graph { graph_descriptor: "G0" graph_id: 0 } }
