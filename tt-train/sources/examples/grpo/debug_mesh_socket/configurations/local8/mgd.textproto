# Mesh Graph Descriptor for the MeshSocket transfer reproducer (4-device per rank).
#
# Two [1, 4] meshes (one per rank), each covering FOUR chips (two eth-linked N300 boards),
# wired together by a FABRIC graph:
#   Rank 0 (sender)   -> mesh_id 0, opens the full [1, 4].
#   Rank 1 (receiver) -> mesh_id 1, opens the full [1, 4].
#
# This is the clean 4/4 split (boards {0,1} | {2,3}): the mesh boundary lands where each
# boundary chip has exactly one cross-mesh peer, so fabric inter-mesh bring-up succeeds.
#
# !!! HARDWARE-SPECIFIC TEMPLATE !!!
# device_topology / channel counts / inter-mesh connection must match your physical wiring
# (each rank's four chips must be eth-connected in a line). Adjust for your machine.

mesh_descriptors {
  name: "M0"
  arch: WORMHOLE_B0
  device_topology { dims: [ 1, 4 ] }
  host_topology   { dims: [ 1, 1 ] }
  channels {
    count: 2
    policy: RELAXED
  }
}

graph_descriptors {
  name: "G0"
  type: "FABRIC"
  instances { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
  instances { mesh { mesh_descriptor: "M0" mesh_id: 1 } }

  connections {
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 1 } }
    channels { count: 2 }
  }
}

top_level_instance { graph { graph_descriptor: "G0" graph_id: 0 } }
