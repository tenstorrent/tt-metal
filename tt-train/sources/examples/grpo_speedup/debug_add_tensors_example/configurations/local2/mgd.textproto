# Mesh Graph Descriptor for the 2-rank "orchestrator + worker" debug example.
#
# Hardware assumption: this runs on a T3K (a.k.a. wh loudbox) -- 4x N300
# boards wired into a 2x4 wormhole mesh of 8 chips. Each board is 1 PCIe
# device with 2 chips (chip 0 reachable over PCIe, chip 1 reachable from
# chip 0 via the on-board eth link). The full physical eth topology must be
# described here, otherwise UMD topology discovery finds eth links to ASICs
# that are not declared in the MGD and ControlPlane::init_control_plane()
# trips `Fabric node ID not yet assigned for ASIC id ...`.
#
# Layout: two [1, 4] line meshes, one per rank, covering all 4 T3K boards.
#   - Rank 0 owns mesh_id 0 -- boards 0+1 (TT_VISIBLE_DEVICES="0,1").
#     The 4 chips snake as: b0c0 -- b1c0 -- b1c1 -- b0c1.
#   - Rank 1 owns mesh_id 1 -- boards 2+3 (TT_VISIBLE_DEVICES="2,3").
#     The 4 chips snake as: b2c0 -- b3c0 -- b3c1 -- b2c1.
#   - The FABRIC graph wires the two halves together so
#     ttnn.experimental.send_async/recv_async can route over the eth links
#     between them (boundary: 2 chip pairs * 2 channels each = 4 channels).
#
# This shape pairs with device_config.mesh_shape=[1, 4] and enable_ddp=true
# (line-topology DDP: parallelism axis = the non-trivial dim 1, length 4).
# To revert to the [2, 2] split bump dims back to [2, 2] and use
# TT_VISIBLE_DEVICES="0,1" / "3,2".

mesh_descriptors {
  name: "M0"
  arch: WORMHOLE_B0
  device_topology { dims: [ 1, 4 ] }
  host_topology   { dims: [ 1, 1 ] }
  channels {
    count: 2
    policy: RELAXED
  }
}

graph_descriptors {
  name: "G0"
  type: "FABRIC"
  instances { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
  instances { mesh { mesh_descriptor: "M0" mesh_id: 1 } }

  connections {
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 1 } }
    channels { count: 4 }
  }
}

top_level_instance { graph { graph_descriptor: "G0" graph_id: 0 } }
