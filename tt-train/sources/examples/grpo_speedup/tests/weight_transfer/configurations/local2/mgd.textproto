# Mesh Graph Descriptor for the 2-rank ttml -> tt-transformers weight bridge test.
#
# Hardware assumption: T3K (a.k.a. wh loudbox) -- 4x N300 boards wired into a
# 2x4 wormhole mesh of 8 chips. Each board is one PCIe device with 2 chips
# (chip 0 reachable over PCIe, chip 1 reachable from chip 0 via the on-board
# eth link). The full physical eth topology must be described here, otherwise
# UMD topology discovery finds eth links to ASICs that are not declared in
# the MGD and ControlPlane::init_control_plane() trips
# `Fabric node ID not yet assigned for ASIC id ...`.
#
# Declared layout: two [1, 2] meshes, one per rank, each covering one full
# N300 board. Matches the canonical N300 MGD
# (tt_metal/fabric/mesh_graph_descriptors/n300_mesh_graph_descriptor.textproto)
# so UMD's topology discovery sees all chips it would naturally find on the
# board.
#
# Used layout (asymmetric):
#   - Rank 0 (TTML) opens the full [1, 2] sub-mesh -- both chips of board 0
#     participate in the ttml model.
#   - Rank 1 (TTT)  opens only a [1, 1] sub-mesh at offset (0, 0) (chip 0 of
#     board 1, the PCIe-reachable one). The second chip is declared so
#     UMD's eth walk has a mapping for it, but it stays idle. The reason
#     for the asymmetry is that the tt-transformers multi-device
#     weight-update path (Attention.update for num_devices_per_group > 1,
#     MLP.update's replicated -> 2D-sharded mesh projection) is not yet
#     implemented; a [1, 1] sub-mesh on the ttt side keeps every
#     Transformer.update_weights dispatch on the single-device fast path.
#
#   - Rank 0 owns mesh_id 0 -- board 0 (TT_VISIBLE_DEVICES="0"). TTML side.
#   - Rank 1 owns mesh_id 1 -- board 1 (TT_VISIBLE_DEVICES="1"). TTT  side.
#   - The FABRIC graph wires the two halves together so
#     ttnn.experimental.send_async/recv_async (used by WeightBridge) can
#     route over the eth links between the two boards.
#
# Pairs with device_config.mesh_shape=[1, 2] + device_ids=[0, 1] on the ttml
# rank, and ttnn.open_mesh_device(mesh_shape=ttnn.MeshShape(1, 1),
# offset=ttnn.MeshCoordinate(0, 0)) on the ttt rank. WeightBridge handles
# the asymmetric pairing by exchanging mesh shapes during ``connect()`` and
# resolving to a single (0, 0) -> (0, 0) ``SocketConnection``.

mesh_descriptors {
  name: "M0"
  arch: WORMHOLE_B0
  device_topology { dims: [ 1, 2 ] }
  host_topology   { dims: [ 1, 1 ] }
  channels {
    count: 2
    policy: RELAXED
  }
}

graph_descriptors {
  name: "G0"
  type: "FABRIC"
  instances { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
  instances { mesh { mesh_descriptor: "M0" mesh_id: 1 } }

  connections {
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 1 } }
    channels { count: 2 }
  }
}

top_level_instance { graph { graph_descriptor: "G0" graph_id: 0 } }
