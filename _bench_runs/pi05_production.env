# Pi0.5 production defaults — single source of truth for the validated 97.2% LIBERO config.
#
# Usage:
#   source _bench_runs/pi05_production.env
#   pytest models/experimental/pi0_5/tests/perf/test_perf_ttnn_full_e2e_trace.py -s
#
# Override any individual flag AFTER sourcing:
#   source _bench_runs/pi05_production.env
#   PI0_NUM_CAMERAS=2 PI05_NUM_DENOISE_STEPS=5 pytest …
#
# Last validated: 2026-06-07, commit e52d0d23cff (97.2% LIBERO at 5 denoise steps).

# === Matmul / kernel tuning (no PCC impact) ===
export PI0_EXPERT_MM_LOFI=1                # denoise expert matmuls at LoFi compute fidelity
export PI0_ROPE_TABLES_L1=1                # RoPE sin/cos tables resident in L1
export PI0_MM_SWEEP_V2=1                   # enable tuned matmul picker v2
export PI0_DENOISE_MM_TUNE=1               # per-shape denoise matmul overrides
export PI0_PREFILL_MM_TUNE=1               # per-shape VLM prefill matmul overrides

# === Attention / mask handling ===
export PI0_UPSTREAM_MASKS=1                # upstream-compat attention mask + RoPE
export QWEN_NLP_CONCAT_HEADS_HEAD_SPLIT=1  # per-head parallelism in NlpConcatHeads
export QWEN_NLP_CREATE_HEADS_HEAD_SPLIT=1  # per-head parallelism in NlpCreateQkvHeads
export PI0_MQA_HEAD_SPLIT=1                # C++ MQA-aware Q-head parallelism in nlp_create_qkv_heads
export PI0_SDPA_DENOISE_K_FORCE=96         # SDPA denoise k_chunk override (1056=96×11 exact divisor)

# === VLM single-pass at bs=3 (training-spec correct) ===
export PI0_NUM_CAMERAS=3                   # 3 image slots per openpi training spec; LIBERO pads slot 3 with -1
export PI0_VLM_CHUNK_SIZE=1024             # single-pass VLM prefill at bs=3 (3·256 img + 256 lang = 1024)
export PI0_VLM_MLP_BF8_OUT=1               # VLM gate/up/down outputs in bfloat8_b (validated ≥0.996 PCC)
export PI0_VLM_MLP_MINIMAL=1               # VLM gate/up routed to ttnn.experimental.minimal_matmul
export PI0_VLM_MINIMAL_CFG=4,8,8,1,8       # minimal_matmul block config: M,K,N,sh,sw
export PI0_SIGLIP_USE_FOLD=1               # patch_embed via ttnn.fold + host pre-stack/pre-reshape (−0.82 ms, LIBERO 388/400)

# === Checkpoint (machine-specific — override in your shell rc if path differs) ===
export PI05_CHECKPOINT_DIR=/home/tt-admin/pi05_cache/pi05_libero_upstream

# === Denoise steps ===
# 5 is the perf-tuned default (~45 ms / inference, validated 97.2% LIBERO).
# Override to 10 to match the upstream training spec (~53 ms / inference).
export PI05_NUM_DENOISE_STEPS=5
