# Mesh graph descriptor for DeepSeek V3 disaggregated prefill cluster.
#
# Topology: 4 Galaxy hosts forming a ring for ring attention.
#   - 1 MPI rank per Galaxy (4 ranks total)
#   - Each Galaxy: 8x4 Blackhole chips (8 SP devices x 4 TP devices)
#   - Inter-Galaxy: ring 0->1->2->3->0, 16 channels each direction
#
# Derived from blitz_decode_mesh_graph_descriptor_superpod.textproto

# --- Meshes ---------------------------------------------------------------

mesh_descriptors {
  name: "M0"
  arch: BLACKHOLE
  # 8 SP devices x 4 TP devices per Galaxy host.
  # RING in SP dimension (supports ring attention all-gather across the Galaxy).
  # LINE in TP dimension.
  device_topology { dims: [ 8, 4 ] dim_types: [ LINE, LINE ] }
  host_topology   { dims: [ 1, 1 ] }
  channels {
    count: 2
    policy: RELAXED
  }
}

graph_descriptors {
  name: "G0"
  type: "FABRIC"
  # 4 Galaxy hosts, one mesh instance per host.
  instances { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
  instances { mesh { mesh_descriptor: "M0" mesh_id: 1 } }
  instances { mesh { mesh_descriptor: "M0" mesh_id: 2 } }
  instances { mesh { mesh_descriptor: "M0" mesh_id: 3 } }

  # Ring connections between Galaxy hosts.
  # 16 channels per link to support ring attention KV all-gather bandwidth.
  # assign_z_direction marks the inter-host links so the fabric can route
  # correctly across physically distinct Galaxy chassis.
  connections {
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 1 } }
    channels { count: 16 policy: RELAXED }
    assign_z_direction: true
  }
  connections {
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 1 } }
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 2 } }
    channels { count: 16 policy: RELAXED }
    assign_z_direction: true
  }
  connections {
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 2 } }
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 3 } }
    channels { count: 16 policy: RELAXED }
    assign_z_direction: true
  }
  # Ring close: Galaxy 3 back to Galaxy 0
  connections {
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 3 } }
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
    channels { count: 16 policy: RELAXED }
    assign_z_direction: true
  }
}

# --- Instantiation ----------------------------------------------------------
top_level_instance { graph { graph_descriptor: "G0" graph_id: 0 } }
