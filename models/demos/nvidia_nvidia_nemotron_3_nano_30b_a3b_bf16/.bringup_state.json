  "use_cases": [
    {
      "name": "text_generation",
      "description": "Autoregressive causal language modeling: generate text tokens given a text prompt, using the hybrid Mamba-2/MoE-Transformer decoder.",
      "input_modality": "text",
      "output_modality": "text",
      "components_used": [
        "Embedding",
        "LayerNorm",
        "RoPE",
        "Mamba2Layer",
        "DenseAttention",
        "DenseMLP",
        "MoEAttention",
        "MoEGate",
        "MoEExperts",
        "SharedExpert",
        "LMHead"
      ],
      "needs_ar": true,
      "needs_audio_out": false,
      "decode_strategy": "kv_cache",
      "hf_class": "NemotronHForCausalLM",
      "validation_metric": "bleu",
      "validation_threshold": "HF - 1.0",
      "hybrid_notes": "KV cache covers only the 6 dense-attention layers and 23 MoE-attention layers. Mamba-2 layers maintain a recurrent SSM hidden state (not KV pairs) \u2014 that state must be managed separately in decode mode. The hybrid_override_pattern (MEMEM*EMEMEM*...) determines per-layer dispatch.",
      "generation": {
        "status": "done",
        "attempts": 2,
        "pcc": 0.999839,
        "notes": "first 6 layers (MEMEM*) hidden-state PCC vs pure-PyTorch reference on QB TP=4 MeshShape(1,4) FABRIC_1D_RING; all 3 layer types covered; call time 9.53s"
      },
      "perf": {
        "status": "done",
        "attempts": 1,
        "decode_latency_ms": 4865,
        "decode_toks_per_sec": 0.21,
        "full_52layer_pcc": 0.995189,
        "notes": "baseline: per-call from_torch weight uploads dominate; optimization phase will add persistent device weight buffers; B=1 S=1 decode, 5 timed runs avg 4865ms"
      }
