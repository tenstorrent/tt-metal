  "use_cases": [
    {
      "name": "text_generation",
      "description": "Autoregressive causal language modeling: generate text tokens given a text prompt, using the hybrid Mamba-2/MoE-Transformer decoder.",
      "input_modality": "text",
      "output_modality": "text",
      "components_used": [
        "Embedding",
        "LayerNorm",
        "RoPE",
        "Mamba2Layer",
        "DenseAttention",
        "DenseMLP",
        "MoEAttention",
        "MoEGate",
        "MoEExperts",
        "SharedExpert",
        "LMHead"
      ],
      "needs_ar": true,
      "needs_audio_out": false,
      "decode_strategy": "kv_cache",
      "hf_class": "NemotronHForCausalLM",
      "validation_metric": "bleu",
      "validation_threshold": "HF - 1.0",
      "hybrid_notes": "KV cache covers only the 6 dense-attention layers and 23 MoE-attention layers. Mamba-2 layers maintain a recurrent SSM hidden state (not KV pairs) — that state must be managed separately in decode mode. The hybrid_override_pattern (MEMEM*EMEMEM*...) determines per-layer dispatch."
    }
  ]
