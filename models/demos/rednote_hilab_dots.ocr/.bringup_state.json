  "use_cases": [
    {
      "name": "ocr",
      "description": "Document image to structured text (OCR / layout parsing): vision tower encodes image patches, embeddings are scattered into the text token stream, and the Qwen2 decoder autoregressively generates the parsed text output.",
      "input_modality": "image",
      "output_modality": "text",
      "components_used": [
        "vision_patch_embed",
        "vision_rmsnorm",
        "vision_attention",
        "vision_mlp",
        "vision_block",
        "vision_patch_merger",
        "vision_tower",
        "embedding",
        "rmsnorm",
        "rope",
        "attention",
        "mlp",
        "decoder_layer",
        "lm_head",
        "language_model"
      ],
      "needs_ar": true,
      "needs_audio_out": false,
      "hf_class": "DotsOCRForCausalLM",
      "validation_metric": "accuracy",
      "validation_threshold": "HF - 1.0",
      "hybrid_notes": "Image preprocessing (resize, patchify into pixel_values + image_grid_thw) and tokenizer/chat-template prompt construction stay on the HF host via DotsVLProcessor (a Qwen2_5_VLProcessor subclass). The masked_scatter of vision embeddings into the input embedding stream is a host/glue op. Text-match accuracy is computed against HF greedy decode on a representative document image.",
      "generation": {
