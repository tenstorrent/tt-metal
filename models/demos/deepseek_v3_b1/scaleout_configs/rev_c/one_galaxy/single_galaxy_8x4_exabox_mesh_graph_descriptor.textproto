# Single 8x4 BH galaxy for exabox CI (bh_spsg). No pinnings — topology discovery picks the host.
# Geometry matches pipeline prefill single-galaxy runs (LINE, RING, RELAXED).

mesh_descriptors {
  name: "M0"
  arch: BLACKHOLE
  device_topology { dims: [ 8, 4 ] dim_types: [ LINE, RING ] }
  host_topology   { dims: [ 1, 1 ] }
  channels {
    count: 2
    policy: RELAXED
  }
}

top_level_instance { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
