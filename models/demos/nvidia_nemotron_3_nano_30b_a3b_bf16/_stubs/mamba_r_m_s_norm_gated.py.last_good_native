    def __init__(self, device, torch_module):
        self.device = device
        self._torch_module = torch_module
        sd = torch_module.state_dict()

        self.weight = ttnn.from_torch(
            sd["weight"],
            layout=ttnn.TILE_LAYOUT,
            dtype=ttnn.bfloat16,
            device=device,
        )
        if "bias" in sd:
            self.bias = ttnn.from_torch(
                sd["bias"],
                layout=ttnn.TILE_LAYOUT,
                dtype=ttnn.bfloat16,
                device=device,
            )
        else:
            self.bias = None
        self.eps = getattr(torch_module, 'eps', 1e-6)

    def _is_mesh(self):
        dev = self.device
        try:
            if isinstance(dev, ttnn.MeshDevice):
                return True
        except AttributeError:
            pass
        return hasattr(dev, "get_device_ids") or hasattr(dev, "get_devices")

    def _to_ttnn(self, t):
        """Materialize an incoming forward arg onto the device as a ttnn
        tensor. The PCC test only converts the *primary* tensor to ttnn;
        secondary args (here: `gate`) arrive as raw torch.Tensors. This is
        plain input materialization (torch->ttnn), NOT a ttnn->torch->CPU
        compute roundtrip, so it stays within the pure-ttnn forward contract.
        """
        if t is None:
            return None
        if isinstance(t, ttnn.Tensor):
            if t.layout != ttnn.TILE_LAYOUT:
                t = ttnn.to_layout(t, ttnn.TILE_LAYOUT)
            return t
        import torch as _torch
        if isinstance(t, _torch.Tensor):
            tt = t.to(_torch.bfloat16)
            if self._is_mesh():
                try:
                    return ttnn.from_torch(
                        tt,
                        dtype=ttnn.bfloat16,
                        layout=ttnn.TILE_LAYOUT,
                        device=self.device,
                        mesh_mapper=ttnn.ReplicateTensorToMesh(self.device),
                    )
                except (AttributeError, TypeError):
                    pass
            return ttnn.from_torch(
                tt,
                dtype=ttnn.bfloat16,
                layout=ttnn.TILE_LAYOUT,
                device=self.device,
            )
        return t

    def __call__(self, hidden_states, gate=None):
        # MambaRMSNormGated (NemotronH / Mamba2): norm_before_gate=False
        #   x = hidden_states * silu(gate)            (gate applied BEFORE norm)
        #   x = grouped_rms_norm(x)                   (per-group over group_size)
        #   out = weight * x                          (per-feature learned scale)
        # group_size = intermediate_size // n_groups = 4096 // 8 = 512.

        # The test converts only the primary tensor to ttnn; `gate` (and, in
        # rare paths, hidden_states) may arrive as a torch.Tensor. Materialize
        # both onto the device before any ttnn op so we never call ttnn.* on a
        # torch tensor (that was the prior TypeError / API_SIGNATURE failure).
        hidden_states = self._to_ttnn(hidden_states)
        gate = self._to_ttnn(gate)

        # Lazy-initialize grouped-norm params (cannot modify __init__).
        if not hasattr(self, '_grp_size'):
            import torch as _torch
            self._grp_size = int(getattr(self._torch_module, 'group_size', 512))
            self._grp_eps = float(getattr(self._torch_module, 'variance_epsilon', self.eps))
            self._ones_w = ttnn.from_torch(
                _torch.ones(self._grp_size),
                layout=ttnn.TILE_LAYOUT,
                dtype=ttnn.bfloat16,
                device=self.device,
                **({"mesh_mapper": ttnn.ReplicateTensorToMesh(self.device)} if self._is_mesh() else {}),
            )

        # Step 1: gate BEFORE norm (norm_before_gate=False) — x = hs * silu(gate)
        if gate is not None:
            gate_silu = ttnn.silu(gate)
            x = ttnn.mul(hidden_states, gate_silu)
        else:
            x = hidden_states

        # Step 2: grouped RMS norm. Reshape (B, L, C) -> (B*L*n_groups, group_size)
        # so ttnn.rms_norm normalizes each contiguous group independently. The
        # learned per-feature `weight` is applied AFTER (Step 3), so use a ones
        # weight here for pure normalization.
        s = list(x.shape)
        B, L, C = int(s[0]), int(s[1]), int(s[2])
        n_groups = C // self._grp_size

        x = ttnn.to_layout(x, ttnn.ROW_MAJOR_LAYOUT)
        x = ttnn.reshape(x, [B * L * n_groups, self._grp_size])
        x = ttnn.to_layout(x, ttnn.TILE_LAYOUT)

        # fp32 accumulation is required for the RMS reduction to hit PCC>=0.99
        # (a bf16/manual mean plateaus below target — see component memory).
        x = ttnn.rms_norm(
            x,
            weight=self._ones_w,
            epsilon=self._grp_eps,
            compute_kernel_config=ttnn.WormholeComputeKernelConfig(
                math_fidelity=ttnn.MathFidelity.HiFi4,
                math_approx_mode=False,
                fp32_dest_acc_en=True,
                packer_l1_acc=False,
            ),
        )

        # Reshape back to (B, L, C).
        x = ttnn.to_layout(x, ttnn.ROW_MAJOR_LAYOUT)
        x = ttnn.reshape(x, [B, L, C])
        x = ttnn.to_layout(x, ttnn.TILE_LAYOUT)

        # Step 3: per-feature learned weight, broadcast over (B, L).
        x = ttnn.mul(x, self.weight)

        return x

