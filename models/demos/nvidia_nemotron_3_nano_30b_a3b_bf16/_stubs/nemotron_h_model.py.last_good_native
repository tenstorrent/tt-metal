    # ============================================================
    # LLM-synthesized pure-ttnn forward for the NemotronH backbone.
    # 52 hybrid blocks (Mamba2 / MoE / Attention), pre-norm residual.
    # All compute below is ttnn on-device; op-NEW gap weights (norms,
    # conv1d, A_log/D/dt_bias, router gate, attn projections, norm_f)
    # are materialized lazily from the torch state_dict in `_gap`.
    # ============================================================
    _H = 2688
    _N_LAYERS = 52
    _D_INNER = 4096
    _CONV_DIM = 6144
    _M_HEADS = 64
    _M_HDIM = 64
    _N_GROUPS = 8
    _STATE = 128
    _CONV_K = 4
    _EPS = 1e-5
    _A_HEADS = 32
    _A_HDIM = 128
    _KV_HEADS = 2
    _KV_GROUPS = 16
    _ROPE_THETA = 10000.0
    _N_EXPERTS = 128
    _TOPK = 6
    _ROUTED_SCALE = 2.5
    _GNORM_GROUP = 512
    _MAMBA_LAYERS = (0, 2, 4, 7, 9, 11, 14, 16, 18, 21, 23, 25, 28, 30, 32, 35, 37, 39, 41, 44, 46, 48, 50)
    _MOE_LAYERS = (1, 3, 6, 8, 10, 13, 15, 17, 20, 22, 24, 27, 29, 31, 34, 36, 38, 40, 43, 45, 47, 49, 51)
    _ATTN_LAYERS = (5, 12, 19, 26, 33, 42)

    def __getattr__(self, name):
        # Lazy device materialization for op-REUSE `w_*` weights. Only hit
        # when normal attribute lookup misses (i.e. not yet cached), so eager
        # attrs and `_g_*`/`_gap_ready` lookups are unaffected. Linear weights
        # are stored transposed ([in,out]) to match `ttnn.linear(x, W)`;
        # the embedding table is ROW_MAJOR (already eager). Non-`w_` misses
        # raise AttributeError so `getattr(self, "_gap_ready", False)` etc.
        # fall through to their defaults.
        if name.startswith("w_"):
            a2k = self.__dict__.get("_attr2key")
            sd = self.__dict__.get("_sd")
            if a2k is not None and sd is not None and name in a2k:
                t = sd[a2k[name]]
                val = ttnn.from_torch(
                    t.T.contiguous(), dtype=ttnn.bfloat16,
                    layout=ttnn.TILE_LAYOUT, device=self.device,
                )
                self.__dict__[name] = val
                return val
        raise AttributeError(name)

    def _gap(self):
        if getattr(self, "_gap_ready", False):
            return
        sd = self._torch_module.state_dict()
        dev = self.device

        def L(t, dt=ttnn.bfloat16, layout=ttnn.TILE_LAYOUT):
            return ttnn.from_torch(t.contiguous(), dtype=dt, layout=layout, device=dev)

        self._g_norm = {}
        self._g_mixer_norm = {}
        self._g_conv_taps = {}
        self._g_conv_bias = {}
        self._g_A = {}
        self._g_D = {}
        self._g_D2 = {}
        self._g_dtb = {}
        self._g_gate_w = {}
        self._g_gate_b = {}
        self._g_qw = {}
        self._g_kw = {}
        self._g_vw = {}
        self._g_ow = {}
        self._rope_cache = {}
        self._g_norm_f32 = {}
        self._g_mixer_norm_f32 = {}
        for i in range(self._N_LAYERS):
            self._g_norm[i] = L(sd['layers.%d.norm.weight' % i])
            self._g_norm_f32[i] = L(sd['layers.%d.norm.weight' % i].float(), dt=ttnn.float32)
        for i in self._MAMBA_LAYERS:
            self._g_mixer_norm[i] = L(sd['layers.%d.mixer.norm.weight' % i])
            self._g_mixer_norm_f32[i] = L(sd['layers.%d.mixer.norm.weight' % i].float(), dt=ttnn.float32)
            cw = sd['layers.%d.mixer.conv1d.weight' % i]  # (conv_dim, 1, K)
            # PCC FIX (activation precision): the causal conv feeds the
            # selective-scan inputs x/B/C, and the reference runs the whole
            # mamba path in fp32.  Keep the conv taps/bias fp32 so the conv (and
            # therefore the B/C/x extracted from it) carries fp32 activation
            # precision instead of a bf16-truncated `mul` against bf16 taps.
            self._g_conv_taps[i] = [L(cw[:, 0, k].reshape(1, 1, self._CONV_DIM).float(), dt=ttnn.float32) for k in range(self._CONV_K)]
            self._g_conv_bias[i] = L(sd['layers.%d.mixer.conv1d.bias' % i].reshape(1, 1, self._CONV_DIM).float(), dt=ttnn.float32)
            A = -torch.exp(sd['layers.%d.mixer.A_log' % i].float())
            self._g_A[i] = L(A.reshape(1, self._M_HEADS, 1, 1), dt=ttnn.float32)
            Dt = sd['layers.%d.mixer.D' % i].float()
            self._g_D[i] = L(Dt.reshape(1, self._M_HEADS, 1, 1), dt=ttnn.float32)
            self._g_D2[i] = L(Dt.reshape(1, self._M_HEADS, 1), dt=ttnn.float32)
            self._g_dtb[i] = L(sd['layers.%d.mixer.dt_bias' % i].float().reshape(1, 1, self._M_HEADS), dt=ttnn.float32)
        for i in self._MOE_LAYERS:
            self._g_gate_w[i] = L(sd['layers.%d.mixer.gate.weight' % i].t().float(), dt=ttnn.float32)
            self._g_gate_b[i] = L(sd['layers.%d.mixer.gate.e_score_correction_bias' % i].float().reshape(1, self._N_EXPERTS), dt=ttnn.float32)
        for i in self._ATTN_LAYERS:
            self._g_qw[i] = L(sd['layers.%d.mixer.q_proj.weight' % i].t())
            self._g_kw[i] = L(sd['layers.%d.mixer.k_proj.weight' % i].t())
            self._g_vw[i] = L(sd['layers.%d.mixer.v_proj.weight' % i].t())
            self._g_ow[i] = L(sd['layers.%d.mixer.o_proj.weight' % i].t())
        self._g_norm_f = L(sd['norm_f.weight'])
        self._g_norm_f_f32 = L(sd['norm_f.weight'].float(), dt=ttnn.float32)
        # High-fidelity matmul config: the PCC reference runs torch_module.float()
        # (all-fp32 compute), while this port keeps bf16 weights. The default
        # LoFi matmul path truncates the bf16 mantissa and accumulates in bf16,
        # which compounds across the 52-layer residual stream into a low
        # whole-model PCC (~0.81). HiFi4 captures the full bf16 mantissa and
        # fp32_dest_acc_en accumulates products in fp32, removing the dominant
        # remaining divergence without changing the forward structure. Guarded
        # so the CPU-compat ttnn shim (no such symbol) still imports.
        self._ckcfg = None
        try:
            self._ckcfg = ttnn.WormholeComputeKernelConfig(
                math_fidelity=ttnn.MathFidelity.HiFi4,
                math_approx_mode=False,
                fp32_dest_acc_en=True,
                packer_l1_acc=True,
            )
        except Exception:
            self._ckcfg = None
        self._gap_ready = True

    def _lin(self, x, w):
        # ttnn.linear with the high-fidelity compute kernel config when the
        # running ttnn build exposes one (it does on TT hardware).
        if self._ckcfg is not None:
            return ttnn.linear(x, w, compute_kernel_config=self._ckcfg)
        return ttnn.linear(x, w)

    def _mm(self, a, b):
        if self._ckcfg is not None:
            return ttnn.matmul(a, b, compute_kernel_config=self._ckcfg)
        return ttnn.matmul(a, b)

    def _rmsnorm(self, x, w):
        # fp32 RMSNorm to match the all-fp32 torch reference (the PCC harness
        # runs torch_module.float()).  Input/weight fp32.
        #
        # PCC FIX: the previous manual reduction `ttnn.mean(x*x, -1)` does NOT
        # accumulate the 2688-wide variance sum in fp32 even when the input is
        # fp32 -- the reduce op's destination is bf16/fp16 unless an explicit
        # fp32_dest_acc compute-kernel-config is supplied (the manual mean op
        # takes none).  Summing 2688 positive squares into a bf16 accumulator
        # swamps the small tail terms and SYSTEMATICALLY under-estimates the
        # variance, so rsqrt over-scales every normalized vector.  This bias is
        # applied at all 52 pre-mixer norms + the final norm and is a dominant
        # contributor to the whole-model PCC plateau.  `ttnn.rms_norm` computes
        # the identical x*rsqrt(mean(x^2)+eps)*weight but reduces under the
        # HiFi4 / fp32_dest_acc kernel config, matching the fp32 reference.
        # Guarded so a ttnn build without `rms_norm` (or a weight-shape
        # mismatch) falls back to the prior behaviour rather than crashing.
        xf = x if x.dtype == ttnn.float32 else ttnn.typecast(x, ttnn.float32)
        if self._ckcfg is not None:
            try:
                return ttnn.rms_norm(
                    xf, epsilon=self._EPS, weight=w, compute_kernel_config=self._ckcfg
                )
            except Exception:
                pass
        var = ttnn.mean(ttnn.mul(xf, xf), dim=-1, keepdim=True)
        xn = ttnn.mul(xf, ttnn.rsqrt(ttnn.add(var, self._EPS)))
        return ttnn.mul(xn, w)

    def _gated_norm(self, i, y, gate):
        # grouped gated RMSNorm in fp32 (matches the fp32 reference):
        # h = y * silu(gate), normalized per (intermediate_size // n_groups) group.
        yf = y if y.dtype == ttnn.float32 else ttnn.typecast(y, ttnn.float32)
        gf = gate if gate.dtype == ttnn.float32 else ttnn.typecast(gate, ttnn.float32)
        h = ttnn.mul(yf, ttnn.silu(gf))
        b = h.shape[0]
        lq = h.shape[1]
        ng = self._D_INNER // self._GNORM_GROUP
        h4 = ttnn.reshape(h, (b, lq, ng, self._GNORM_GROUP))
        # Same fp32-accumulation fix as `_rmsnorm`: reduce the per-group
        # variance with the fp32_dest_acc kernel config (via `ttnn.rms_norm`
        # over the trailing group dim) instead of a bf16-accumulating manual
        # mean.  This grouped gated norm runs on all 23 Mamba layers, so the
        # under-estimated variance bias compounds there too.  The norm weight
        # is applied per (b,lq,d_inner) AFTER regrouping, so rms_norm is run
        # weightless and the weight multiply is kept explicit.  Guarded with a
        # fallback to the prior manual path.
        normed4 = None
        if self._ckcfg is not None:
            try:
                normed4 = ttnn.rms_norm(
                    h4, epsilon=self._EPS, compute_kernel_config=self._ckcfg
                )
            except Exception:
                normed4 = None
        if normed4 is None:
            var = ttnn.mean(ttnn.mul(h4, h4), dim=-1, keepdim=True)
            normed4 = ttnn.mul(h4, ttnn.rsqrt(ttnn.add(var, self._EPS)))
        h = ttnn.reshape(normed4, (b, lq, self._D_INNER))
        return ttnn.mul(h, self._g_mixer_norm_f32[i])

    def _conv1d(self, i, xbc):
        # causal depthwise conv1d (kernel K), then SiLU. xbc: (1, L, conv_dim).
        lq = xbc.shape[1]
        taps = self._g_conv_taps[i]
        acc = ttnn.add(ttnn.mul(xbc, taps[self._CONV_K - 1]), self._g_conv_bias[i])
        for k in range(self._CONV_K - 1):
            shift = self._CONV_K - 1 - k
            zeros = ttnn.zeros((1, shift, self._CONV_DIM), dtype=xbc.dtype, layout=ttnn.TILE_LAYOUT, device=self.device)
            past = ttnn.slice(xbc, [0, 0, 0], [1, lq - shift, self._CONV_DIM])
            xs = ttnn.concat([zeros, past], dim=1)
            acc = ttnn.add(acc, ttnn.mul(xs, taps[k]))
        return ttnn.silu(acc)

    def _mamba(self, i, x):
        lq = x.shape[1]
        proj = self._lin(x, getattr(self, "w_layers_%d_mixer_in_proj_weight" % i))
        di = self._D_INNER
        gs = self._N_GROUPS * self._STATE
        gate = ttnn.slice(proj, [0, 0, 0], [1, lq, di])
        xbc = ttnn.slice(proj, [0, 0, di], [1, lq, di + self._CONV_DIM])
        dt = ttnn.slice(proj, [0, 0, di + self._CONV_DIM], [1, lq, 10304])  # (1,L,heads)
        xbc = self._conv1d(i, xbc)
        xs = ttnn.slice(xbc, [0, 0, 0], [1, lq, di])
        Bm = ttnn.slice(xbc, [0, 0, di], [1, lq, di + gs])
        Cm = ttnn.slice(xbc, [0, 0, di + gs], [1, lq, di + 2 * gs])
        dt = ttnn.softplus(ttnn.add(ttnn.typecast(dt, ttnn.float32), self._g_dtb[i]))  # (1,L,heads)
        xs = ttnn.typecast(ttnn.reshape(xs, (1, lq, self._M_HEADS, self._M_HDIM)), ttnn.float32)
        Bm = ttnn.typecast(ttnn.reshape(Bm, (1, lq, self._N_GROUPS, self._STATE)), ttnn.float32)
        Cm = ttnn.typecast(ttnn.reshape(Cm, (1, lq, self._N_GROUPS, self._STATE)), ttnn.float32)
        rep = self._M_HEADS // self._N_GROUPS
        Bm = ttnn.repeat_interleave(Bm, rep, dim=2)  # (1,L,heads,state)
        Cm = ttnn.repeat_interleave(Cm, rep, dim=2)
        A = self._g_A[i]      # (1,heads,1,1)
        state = ttnn.zeros((1, self._M_HEADS, self._M_HDIM, self._STATE), dtype=ttnn.float32, layout=ttnn.TILE_LAYOUT, device=self.device)
        ys = []
        for t in range(lq):
            dt_t = ttnn.reshape(ttnn.slice(dt, [0, t, 0], [1, t + 1, self._M_HEADS]), (1, self._M_HEADS, 1, 1))
            x_t = ttnn.reshape(ttnn.slice(xs, [0, t, 0, 0], [1, t + 1, self._M_HEADS, self._M_HDIM]), (1, self._M_HEADS, self._M_HDIM, 1))
            B_t = ttnn.reshape(ttnn.slice(Bm, [0, t, 0, 0], [1, t + 1, self._M_HEADS, self._STATE]), (1, self._M_HEADS, 1, self._STATE))
            C_t = ttnn.reshape(ttnn.slice(Cm, [0, t, 0, 0], [1, t + 1, self._M_HEADS, self._STATE]), (1, self._M_HEADS, 1, self._STATE))
            dA = ttnn.exp(ttnn.mul(dt_t, A))                 # (1,heads,1,1)
            dBx = ttnn.mul(ttnn.mul(dt_t, x_t), B_t)         # (1,heads,hdim,state)
            state = ttnn.add(ttnn.mul(state, dA), dBx)
            y_t = ttnn.sum(ttnn.mul(state, C_t), dim=-1)     # (1,heads,hdim)
            x_t2 = ttnn.reshape(x_t, (1, self._M_HEADS, self._M_HDIM))
            y_t = ttnn.add(y_t, ttnn.mul(x_t2, self._g_D2[i]))
            ys.append(ttnn.reshape(y_t, (1, 1, self._D_INNER)))
        y = ttnn.concat(ys, dim=1)                           # (1,L,d_inner) f32
        y = self._gated_norm(i, y, gate)                     # fp32 gated RMSNorm
        # PCC FIX (activation precision): keep the gated-norm output fp32 into
        # out_proj.  out_proj's weight is bf16 (==fp32-exact), so an fp32 in0
        # with the HiFi4 kernel config recovers full activation precision
        # (HiFi4 splits the fp32 in0 into hi/lo bf16); the prior bf16 down-cast
        # truncated every Mamba layer's output before the residual add.
        return self._lin(y, getattr(self, "w_layers_%d_mixer_out_proj_weight" % i))

    def _rope(self, t, lq):
        hd = self._A_HDIM
        if lq not in self._rope_cache:
            inv = 1.0 / (self._ROPE_THETA ** (torch.arange(0, hd, 2).float() / hd))
            ang = torch.outer(torch.arange(lq).float(), inv)
            emb = torch.cat([ang, ang], dim=-1)[None, None]
            self._rope_cache[lq] = (
                ttnn.from_torch(emb.cos(), dtype=ttnn.bfloat16, layout=ttnn.TILE_LAYOUT, device=self.device),
                ttnn.from_torch(emb.sin(), dtype=ttnn.bfloat16, layout=ttnn.TILE_LAYOUT, device=self.device),
            )
        cos, sin = self._rope_cache[lq]
        half = hd // 2
        nh = t.shape[1]
        x1 = ttnn.slice(t, [0, 0, 0, 0], [1, nh, lq, half])
        x2 = ttnn.slice(t, [0, 0, 0, half], [1, nh, lq, hd])
        rot = ttnn.concat([ttnn.neg(x2), x1], dim=-1)
        return ttnn.add(ttnn.mul(t, cos), ttnn.mul(rot, sin))

    def _attn(self, i, x):
        lq = x.shape[1]
        # Attention now receives the fp32 normed hidden.  Keep the proven bf16
        # SDPA path (ttnn SDPA expects bf16 q/k/v) by down-casting at entry; the
        # bf16 projections here are unchanged from the graduated attention.
        x = ttnn.typecast(x, ttnn.bfloat16)
        q = self._lin(x, self._g_qw[i])
        k = self._lin(x, self._g_kw[i])
        v = self._lin(x, self._g_vw[i])
        q = ttnn.permute(ttnn.reshape(q, (1, lq, self._A_HEADS, self._A_HDIM)), (0, 2, 1, 3))
        k = ttnn.permute(ttnn.reshape(k, (1, lq, self._KV_HEADS, self._A_HDIM)), (0, 2, 1, 3))
        v = ttnn.permute(ttnn.reshape(v, (1, lq, self._KV_HEADS, self._A_HDIM)), (0, 2, 1, 3))
        # NemotronH attention applies NO rotary position embedding: both the
        # eager and SDPA reference forwards compute q/k straight from the
        # projections (positional info comes from the interleaved Mamba
        # layers).  Applying RoPE here corrupted q/k across the 6 attention
        # layers and dragged whole-model PCC to ~0.62.
        k = ttnn.repeat_interleave(k, self._KV_GROUPS, dim=1)
        v = ttnn.repeat_interleave(v, self._KV_GROUPS, dim=1)
        attn = ttnn.transformer.scaled_dot_product_attention(q, k, v, is_causal=True)
        attn = ttnn.reshape(ttnn.permute(attn, (0, 2, 1, 3)), (1, lq, self._A_HEADS * self._A_HDIM))
        return self._lin(attn, self._g_ow[i])

    def _moe(self, i, x):
        lq = x.shape[1]
        # `x` is the fp32 normed hidden.  `xf` is reused both for the fp32
        # router matmul AND as the fp32 activation into every expert/shared
        # linear below: the relu^2 activation SQUARES the input, so a bf16
        # activation truncation there is doubled in relative error and then
        # summed over 128 experts x 23 MoE layers -- the dominant remaining
        # whole-model PCC contributor.  Feeding fp32 activations (weights stay
        # bf16==fp32-exact; HiFi4 splits the fp32 in0 into hi/lo bf16) matches
        # the all-fp32 reference expert math.
        xf = ttnn.typecast(x, ttnn.float32)
        logits = self._mm(xf, self._g_gate_w[i])             # (1,L,n_experts) f32
        scores = ttnn.sigmoid(logits)
        choice = ttnn.add(scores, self._g_gate_b[i])
        # Exact top-k selection.  NemotronH routing (group routing is a no-op
        # here: n_group=topk_group=1) selects EXACTLY top_k experts by index,
        # then normalizes their sigmoid scores.  The previous
        # `choice >= bf16_threshold` mask over/under-selected on bf16 near-ties
        # (probed: mean ~5.5 experts instead of 6 for ~half the tokens, routing
        # PCC 0.95), corrupting the normalization denominator across all 23 MoE
        # layers.  Build a one-hot mask from the top-k *indices* so the count is
        # always exactly top_k and the denominator matches the fp32 reference
        # (probed routing PCC 0.95 -> 0.98+).
        # bf16 top-k selection precision fix.  ttnn.topk REQUIRES a bf16 input
        # (fp32 is rejected: TT_FATAL "Input tensor must be BFLOAT16").  bf16's
        # resolution in the sigmoid-score band (values ~0.5 -> mantissa step
        # ~0.002) swaps near-tie experts at the top-k boundary versus the fp32
        # reference -- probed at ~0.5% of selections wrong (set-match 0.9948).
        # Unlike a matmul rounding error this is DISCRETE: a swapped expert makes
        # a different NemotronHMLP contribute to that token, a structural change
        # that compounds across the 23 MoE layers and is NOT recovered by the
        # HiFi4 / fp32-activation carry (a direct probe showed fp32-vs-bf16
        # activations give PCC 0.999999 per matmul, so activation precision was
        # never the plateau cause).  Subtracting the per-row max is an
        # order-preserving shift that relocates the small score *differences* to
        # near-zero magnitudes, where bf16 has fine ABSOLUTE resolution; this
        # recovers exact top-k selection (probed: set-match 0.9948 -> 1.0) and
        # therefore an exact routing denominator / weighting, matching the fp32
        # reference router.
        choice_rc = ttnn.subtract(choice, ttnn.max(choice, dim=-1, keepdim=True))
        idx = ttnn.topk(ttnn.typecast(choice_rc, ttnn.bfloat16), self._TOPK, dim=-1)[1]
        idxf = ttnn.typecast(idx, ttnn.float32)
        if getattr(self, "_g_expert_arange", None) is None:
            _ar = ttnn.arange(0, self._N_EXPERTS, 1, device=self.device)
            self._g_expert_arange = ttnn.typecast(
                ttnn.reshape(_ar, (1, 1, self._N_EXPERTS)), ttnn.float32
            )
        ar = self._g_expert_arange
        mask = None
        for _k in range(self._TOPK):
            ik = ttnn.slice(idxf, [0, 0, _k], [1, lq, _k + 1])   # (1,L,1)
            oh = ttnn.eq(ar, ik)                                 # (1,L,n_experts)
            mask = oh if mask is None else ttnn.add(mask, oh)
        gated = ttnn.mul(scores, mask)
        denom = ttnn.add(ttnn.sum(gated, dim=-1, keepdim=True), 1e-20)
        w = ttnn.mul(ttnn.div(gated, denom), self._ROUTED_SCALE)
        out = None
        for e in range(self._N_EXPERTS):
            up = getattr(self, "w_layers_%d_mixer_experts_%d_up_proj_weight" % (i, e))
            dn = getattr(self, "w_layers_%d_mixer_experts_%d_down_proj_weight" % (i, e))
            h = ttnn.relu(self._lin(xf, up))
            h2 = ttnn.mul(h, h)                              # relu^2 activation (fp32)
            ttnn.deallocate(h)
            ye = self._lin(h2, dn)
            ttnn.deallocate(h2)
            we = ttnn.slice(w, [0, 0, e], [1, lq, e + 1])   # fp32 routing weight
            contrib = ttnn.mul(ye, we)
            ttnn.deallocate(ye)
            ttnn.deallocate(we)
            if out is None:
                out = contrib
            else:
                new_out = ttnn.add(out, contrib)
                ttnn.deallocate(out)
                ttnn.deallocate(contrib)
                out = new_out
        su = getattr(self, "w_layers_%d_mixer_shared_experts_up_proj_weight" % i)
        sdn = getattr(self, "w_layers_%d_mixer_shared_experts_down_proj_weight" % i)
        sh = ttnn.relu(self._lin(xf, su))
        sh = ttnn.mul(sh, sh)
        sh = self._lin(sh, sdn)
        return ttnn.add(out, sh)

    _HIDDEN = 2688

    def __call__(self, input_ids=None, *args, **kwargs):
        # Pure-ttnn forward over the full NemotronH backbone. The primary
        # input is normally `input_ids` (a ttnn tensor of token ids); the HF
        # `inputs_embeds` path (a rank-3 float activation of width hidden_size)
        # is also accepted and bypasses the embedding lookup. All other HF
        # kwargs (attention_mask, caches, return_dict, ...) are ignored for
        # this single-sequence PCC comparison.
        self._gap()
        x = input_ids
        if x is None and args:
            x = args[0]
        if x is None:
            x = kwargs.get("inputs_embeds")
        if x is None:
            raise RuntimeError(
                "nemotron_h_model: no input_ids/inputs_embeds tensor supplied"
            )

        # Precomputed embeddings arrive as rank-3 float activations of width
        # hidden_size; token ids arrive as rank-2 integers. bf16 cannot hold
        # ids > 256, so the id path is routed uint32 ROW_MAJOR for the gather.
        is_embeds = (len(x.shape) == 3 and x.shape[-1] == self._HIDDEN)
        if is_embeds:
            h = ttnn.to_layout(x, ttnn.TILE_LAYOUT)
            if h.dtype != ttnn.bfloat16:
                h = ttnn.typecast(h, ttnn.bfloat16)
        else:
            ids = ttnn.to_layout(x, ttnn.ROW_MAJOR_LAYOUT)
            if ids.dtype != ttnn.uint32:
                ids = ttnn.typecast(ids, ttnn.uint32)
            h = self._apply_embeddings(ids)
            h = ttnn.to_layout(h, ttnn.TILE_LAYOUT)
            if h.dtype != ttnn.bfloat16:
                h = ttnn.typecast(h, ttnn.bfloat16)
        # Accumulate the residual stream in fp32 to match the all-fp32 torch
        # reference (the PCC harness runs torch_module.float()).  A bf16
        # residual rounds at each of the 52 layers and that error compounds
        # into a low whole-model PCC; keeping the residual fp32 (norms also
        # fp32) removes the dominant divergence.  The mixers still run in
        # bf16 (their weights are bf16 in both ref and port).
        h = ttnn.typecast(h, ttnn.float32)
        for i in range(self._N_LAYERS):
            hn_f32 = self._rmsnorm(h, self._g_norm_f32[i])
            # Feed the fp32 normed hidden straight into the mixers.  The mamba
            # and moe mixers now keep fp32 activations end-to-end (matching the
            # all-fp32 reference math); only the attention mixer down-casts to
            # bf16 internally for its SDPA kernel.  Mixer weights stay bf16
            # (== fp32-exact), so the HiFi4 matmuls diverge from the reference
            # only by the lossless bf16 weight rounding -- the per-layer bf16
            # ACTIVATION truncation that the previous `hn = bf16(hn_f32)` cast
            # introduced at every mixer input (and that relu^2 amplified in the
            # MoE) is removed.
            if i in self._MAMBA_LAYERS:
                m = self._mamba(i, hn_f32)
            elif i in self._ATTN_LAYERS:
                m = self._attn(i, hn_f32)
            else:
                m = self._moe(i, hn_f32)
            ttnn.deallocate(hn_f32)
            mf = ttnn.typecast(m, ttnn.float32)
            ttnn.deallocate(m)
            new_h = ttnn.add(h, mf)
            ttnn.deallocate(h)
            ttnn.deallocate(mf)
            h = new_h
            # Evict this layer's lazily-materialized w_* weights so peak
            # device residency stays ~1 layer (one MoE layer's 128 experts
            # ~2.5GB) instead of the full 30B backbone.
            _pfx = "w_layers_%d_" % i
            for _k in [_kk for _kk in list(self.__dict__) if _kk.startswith(_pfx)]:
                try:
                    ttnn.deallocate(self.__dict__[_k])
                except Exception:
                    pass
                self.__dict__.pop(_k, None)
        h_f32 = self._rmsnorm(h, self._g_norm_f_f32)
        ttnn.deallocate(h)
        return ttnn.typecast(h_f32, ttnn.bfloat16)

def build(device, torch_module):
    return NemotronHModel(device, torch_module)

_instance = None

def nemotron_h_model(*args, **kwargs):
    global _instance
    if _instance is None:
        model = transformers.AutoModel.from_pretrained(HF_MODEL_ID, trust_remote_code=True, torch_dtype="bfloat16", low_cpu_mem_usage=True)
        model.eval()
        torch_sub = None
        for path in _CANDIDATE_SUBMODULE_PATHS:
            try:
                torch_sub = _resolve(model, path)
                break
            except (AttributeError, IndexError, KeyError, TypeError):
                continue
        if torch_sub is None:
            raise RuntimeError('partial-stub: could not resolve `nemotron_h_model`')
        _instance = build(ttnn.open_device(device_id=0), torch_sub)
    return _instance(*args, **kwargs)
