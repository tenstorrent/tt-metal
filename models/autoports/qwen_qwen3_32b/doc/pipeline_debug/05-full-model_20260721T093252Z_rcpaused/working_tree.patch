+def _paged_prefill_capacity(max_cache_len: int, page_block_size: int = PAGE_BLOCK_SIZE) -> int:
+    """Physical paged-cache extent needed to cover a logical context."""
+
+    if max_cache_len < 1:
+        raise ValueError(f"max_cache_len must be positive, got {max_cache_len}")
+    if page_block_size < 32 or page_block_size % 32:
+        raise ValueError("page_block_size must be a positive multiple of 32")
+    return page_block_size * math.ceil(max_cache_len / page_block_size)
+
+
+def _rotary_table_rows(max_cache_len: int, page_block_size: int = PAGE_BLOCK_SIZE) -> int:
+    """Cover page-padded prefill and one decode standby row on whole tiles."""
+
+    required = max(_paged_prefill_capacity(max_cache_len, page_block_size), max_cache_len + 1)
+    return 32 * math.ceil(required / 32)
+
