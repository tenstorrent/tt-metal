+def _clamp_model_max_length(
+    model_kwargs: dict, device_max_context: Optional[int], task_name: str
+) -> dict:
+    """Return model_kwargs with max_length no larger than the served context."""
+    if not device_max_context:
+        return model_kwargs
+    requested_raw = model_kwargs.get("max_length")
+    if requested_raw is None:
+        out = dict(model_kwargs)
+        out["max_length"] = device_max_context
+        return out
+    try:
+        requested = int(requested_raw)
+    except (TypeError, ValueError):
+        return model_kwargs
+    if requested <= device_max_context:
+        return model_kwargs
+    out = dict(model_kwargs)
+    out["max_length"] = device_max_context
+    logger.info(
+        f"Clamping {task_name} max_length: "
+        f"{requested} -> {device_max_context} "
+        f"(device_model_spec.max_context={device_max_context})"
+    )
+    return out
+
+
