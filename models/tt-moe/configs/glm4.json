{
  "moe_block": {
    "model_params": {
      "model_type": "glm4",
      "num_experts": 128,
      "num_experts_per_tok": 8,
      "hidden_size": 4096,
      "intermediate_size": 10944,
      "moe_intermediate_size": 1408,
      "n_group": 1,
      "topk_group": 1,
      "n_shared_experts": 1
    },
    "shared_expert_placement": "internal",
    "router": {
      "type": "grouped_topk",
      "score_correction_bias": true,
      "norm_topk_prob": true,
      "routed_scaling_factor": 1.0
    },
    "experts": {
      "distributed": true,
      "shared": true,
      "shared_parallel": true,
      "quantized": true,
      "weight_block_size": [128, 128],
      "activation": "swiglu",
      "matmul_type": "dense"
    },
    "tensor_parallel": {
      "enabled": true,
      "axis": 1
    },
    "expert_parallel": {
      "enabled": true,
      "axis": 0
    },
    "replicated_batch_mode": true,
    "chunking": {
      "moe_chunk_size": 4096,
      "prefill_chunk_size": 16384
    }
  }
}
