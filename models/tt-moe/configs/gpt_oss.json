{
  "moe_block": {
    "model_params": {
      "num_experts": 128,
      "num_experts_per_tok": 4,
      "hidden_size": 2880,
      "intermediate_size": 360
    },

    "router": {
      "type": "topk",
      "use_throughput_experts": true
    },

    "experts": {
      "distributed": true,
      "shared": false,
      "quantized": false,
      "activation": "swiglu",
      "swiglu_limit": 7.0
    },

    "tensor_parallel": {
      "enabled": true,
      "axis": 1
    },

    "expert_parallel": {
      "enabled": true,
      "axis": 0
    },

    "replicated_batch_mode": false,

    "weight_path": "/path/to/gpt-oss/weights",
    "layer_index": 0,
    "module_prefix": "model.layers.0"
  }
}
