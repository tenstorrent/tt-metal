# Build stage: compile tt-metal from source
FROM ubuntu:24.04 AS builder

RUN mkdir /tt-metal
WORKDIR /tt-metal

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    apt-get update && apt-get install -y python3 python3-pip git

COPY scripts/install-uv.sh /tmp/install-uv.sh
RUN chmod +x /tmp/install-uv.sh && /tmp/install-uv.sh --system

RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install --system setuptools

## Install Metal dependencies
COPY install_dependencies.sh .
COPY tt_metal/sfpi-info.sh tt_metal/
COPY tt_metal/sfpi-version tt_metal/
COPY scripts/ttexalens_ref.txt scripts/
RUN ./install_dependencies.sh --docker

# Install ccache
RUN mkdir -p /usr/local/bin && wget -O /tmp/ccache.tar.xz https://github.com/ccache/ccache/releases/download/v4.12.2/ccache-4.12.2-linux-x86_64.tar.xz && \
    tar -xf /tmp/ccache.tar.xz -C /usr/local/bin --strip-components=1 && \
    rm /tmp/ccache.tar.xz

COPY . .

ARG BUILD_METAL_ARGS=""

RUN --mount=type=cache,target=/tt-metal/.cpmcache,sharing=locked,id=cpm \
    ./build_metal.sh $BUILD_METAL_ARGS --configure-only --cpm-source-cache /tt-metal/.cpmcache --build-dir /usr --enable-ccache

RUN --mount=type=secret,id=CCACHE_REMOTE_STORAGE \
    --mount=type=cache,target=/tt-metal/.cpmcache,sharing=shared,id=cpm \
    export CCACHE_REMOTE_STORAGE=$(cat /run/secrets/CCACHE_REMOTE_STORAGE) && \
    export CCACHE_REMOTE_ONLY=1 && \
    cmake --build /usr --target install

# Build the wheel for clean install in runtime stage
RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install --system build && \
    python3 -m build --wheel --outdir /tmp/wheels .

# Runtime stage: clean image with only what's needed to run
FROM ubuntu:24.04 AS runtime

RUN mkdir /tt-metal
WORKDIR /tt-metal

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    apt-get update && apt-get install -y python3 python3-pip git

COPY scripts/install-uv.sh /tmp/install-uv.sh
RUN chmod +x /tmp/install-uv.sh && /tmp/install-uv.sh --system

# Copy requirement files and install Python deps
COPY tt_metal/python_env/requirements-dev.txt tt_metal/python_env/
COPY tt_metal/python_env/requirements-core.txt tt_metal/python_env/
COPY tt_metal/python_env/requirements-dev-tools.txt tt_metal/python_env/
COPY tt_metal/python_env/requirements-models.txt tt_metal/python_env/
COPY tt_metal/python_env/requirements-notebooks.txt tt_metal/python_env/
COPY docs/requirements-docs.txt docs/
COPY tests/sweep_framework/requirements-sweeps.txt tests/sweep_framework/
COPY tools/triage/requirements.txt tools/triage/
RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install --system setuptools && \
    uv pip install --system -r tt_metal/python_env/requirements-dev.txt

# Install Metal system dependencies
COPY install_dependencies.sh .
COPY tt_metal/sfpi-info.sh tt_metal/
COPY tt_metal/sfpi-version tt_metal/
COPY scripts/ttexalens_ref.txt scripts/
RUN ./install_dependencies.sh --docker

# Install slurmd
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    apt-get update && apt-get install -y slurmd

# Copy built artifacts from builder: installed libraries and wheel
COPY --from=builder /usr/libexec/tt-metalium /usr/libexec/tt-metalium
COPY --from=builder /usr/lib/libtt_metal*.so* /usr/lib/
COPY --from=builder /usr/include/tt-metalium /usr/include/tt-metalium
COPY --from=builder /tmp/wheels/*.whl /tmp/wheels/

# Install the wheel
RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install --system /tmp/wheels/*.whl && \
    rm -rf /tmp/wheels

# MPI uses non-root users and some tests write here
RUN chmod -R 777 /usr/libexec/tt-metalium

WORKDIR /root
