+    def weight_cache_path(self, dtype):
+        # Use a versioned subdirectory so that any stale q/k-norm or embed
+        # tensors cached before the reverse_permute_1d + standardize_hf_keys
+        # fixes (2026-05-24) are never silently reused.  ttnn.as_tensor reads
+        # from cache when the file exists, bypassing the Python conversion
+        # entirely, so a stale file (e.g. identity q_norm written before the
+        # key-routing fix) will persist across runs until the path changes.
+        import ttnn as _ttnn
+
+        if self.instruct:
+            _subdir = {
+                _ttnn.bfloat16: "tensor_cache_instruct_bf16_v2",
+                _ttnn.bfloat8_b: "tensor_cache_instruct_bfp8_v2",
+            }[dtype]
+        else:
+            _subdir = {_ttnn.bfloat16: "tensor_cache_bf16_v2", _ttnn.bfloat8_b: "tensor_cache_bfp8_v2"}[dtype]
+        return self.model_cache_path / _subdir
+
