             selected_dict = other_state_dict
@@ -37,9 +51,24 @@ def map_vision_hf_to_meta_keys_split_to_submodels(state_dict):
 def map_vision_hf_to_meta_keys(state_dict, head_dim):
     vision_state_dict, text_state_dict, other_state_dict = map_vision_hf_to_meta_keys_split_to_submodels(state_dict)
 
+    # q/k norm weights MUST be reverse_permute_1d'd (HF separate-halves layout →
+    # Meta interleaved layout) so the RMSNorm scale lines up with Q/K activations,
+    # which are in Meta interleaved layout after nlp_create_qkv_heads (because the
+    # Q/K projection weights were reverse_permute'd). Leaving them unpermuted while
+    # Q/K are permuted scrambles per-frequency normalization and produces a
+    # coherent prefix followed by repetition collapse during decode. Extract them
+    # so `convert_hf_qkv_to_meta_format` doesn't try to apply the QKV-projection
+    # `reverse_permute` (n_heads-based) to them, then apply the 1d variant here.
+    qk_norm_keys = [k for k in list(text_state_dict) if "q_norm.weight" in k or "k_norm.weight" in k]
+    qk_norm_dict = {k: text_state_dict.pop(k) for k in qk_norm_keys}
+
     text_state_dict = convert_hf_qkv_to_meta_format(text_state_dict, head_dim)
     text_state_dict = map_hf_to_meta_keys(text_state_dict)
 
+    qk_norm_dict = {k: reverse_permute_1d(v) for k, v in qk_norm_dict.items()}
+    qk_norm_dict = map_hf_to_meta_keys(qk_norm_dict)
+    text_state_dict.update(qk_norm_dict)
+
     vision_state_dict = map_hf_to_meta_keys_vision_only(vision_state_dict)
 
     return {**vision_state_dict, **text_state_dict, **other_state_dict}
