+def _normalize_token_result_to_list(result):
+    """2026-05-23 transformers-5.x compat helper.
+
+    `apply_chat_template(tokenize=True)` in transformers 5.x with the
+    new `TokenizersBackend` returns a `BatchEncoding` (dict-like with
+    `.input_ids`), NOT a flat `List[int]` like 4.x. Older code paths
+    that do `torch.tensor(encoded[:])` then crash with
+    `RuntimeError: Could not infer dtype of tokenizers.Encoding`.
+
+    Normalize the return type so every caller gets a flat
+    `List[int]` regardless of transformers version / tokenizer
+    backend. Handles three cases:
+      * BatchEncoding (transformers 5.x TokenizersBackend) -> .input_ids
+      * tokenizers.Encoding (raw Rust object)               -> .ids
+      * List[int] (transformers 4.x)                        -> identity
+    """
+    if hasattr(result, "input_ids"):
+        return list(result.input_ids)
+    if hasattr(result, "ids"):
+        return list(result.ids)
+    return result
