index 00000000000..2fc98ecc97c
--- /dev/null
+++ b/tt_metal/api/tt-metalium/experimental/metal2_host_api/runtime_arg_name.hpp
@@ -0,0 +1,78 @@
+// SPDX-FileCopyrightText: © 2026 Tenstorrent USA, Inc.
+//
+// SPDX-License-Identifier: Apache-2.0
+
+#pragma once
+
+#include <cstddef>
+#include <cstdint>
+#include <cstring>
+#include <functional>
+#include <string>
+#include <string_view>
+
+#include <fmt/format.h>
+#include <tt_stl/assert.hpp>
+
+namespace tt::tt_metal::experimental {
+
+// Owning, heap-free key for per-node runtime-argument tables (see RuntimeArgValues in
+// program_run_args.hpp). It replaces std::string as the key type to avoid a heap
+// allocation per argument name, per node: runtime-arg names are short identifiers known
+// at compile time, so storing them in a small inline buffer keeps the per-node
+// RuntimeArgValues tables malloc-free both when a factory builds them and when they are
+// copied through ProgramRunArgs. Implicitly constructible from the same string literals /
+// std::string the factories already use, so no factory-side code changes are required.
+class RtaName {
+public:
+    // Holds names up to 31 chars inline, making sizeof(RtaName) == 32 bytes (cache-friendly,
+    // cheap to copy). The constructor hard-fails if a name does not fit; the only current
+    // names that exceed this are the ~33-char matmul-reuse-optimized stride args, which
+    // should be shortened.
+    static constexpr std::size_t kCapacity = 31;
+
+    RtaName() = default;
+
+    // Implicit on purpose: factories write `{{"name", value}, ...}` and the framework
+    // looks tables up with std::string / string_view schema names.
+    RtaName(std::string_view s) {
+        TT_FATAL(
+            s.size() <= kCapacity,
+            "Runtime-arg name '{}' is {} chars but RtaName holds at most {}; bump RtaName::kCapacity.",
+            s,
+            s.size(),
+            kCapacity);
+        len_ = static_cast<std::uint8_t>(s.size());
+        std::memcpy(data_, s.data(), len_);
+    }
+    RtaName(const char* s) : RtaName(std::string_view(s)) {}
+    RtaName(const std::string& s) : RtaName(std::string_view(s)) {}
+
+    [[nodiscard]] std::string_view view() const noexcept { return {data_, len_}; }
+    [[nodiscard]] std::size_t size() const noexcept { return len_; }
+    [[nodiscard]] bool empty() const noexcept { return len_ == 0; }
+
+    bool operator==(const RtaName& other) const noexcept {
+        return len_ == other.len_ && std::memcmp(data_, other.data_, len_) == 0;
+    }
+
+private:
+    std::uint8_t len_ = 0;
+    char data_[kCapacity] = {};
+};
+
+}  // namespace tt::tt_metal::experimental
+
+template <>
+struct std::hash<tt::tt_metal::experimental::RtaName> {
+    std::size_t operator()(const tt::tt_metal::experimental::RtaName& n) const noexcept {
+        return std::hash<std::string_view>{}(n.view());
+    }
+};
+
+template <>
+struct fmt::formatter<tt::tt_metal::experimental::RtaName> : fmt::formatter<std::string_view> {
+    auto format(const tt::tt_metal::experimental::RtaName& n, fmt::format_context& ctx) const {
+        return fmt::formatter<std::string_view>::format(n.view(), ctx);
+    }
+};
