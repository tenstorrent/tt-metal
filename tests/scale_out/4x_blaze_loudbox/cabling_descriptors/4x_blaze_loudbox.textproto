# Node descriptor for P150 Loudbox (8x P150 boards)
node_descriptors {
  key: "P150_LB"
  value {
    motherboard: "H13DSG-O-CPU"
    boards {
      board { tray_id: 1 board_type: "P150" }
      board { tray_id: 2 board_type: "P150" }
      board { tray_id: 3 board_type: "P150" }
      board { tray_id: 4 board_type: "P150" }
      board { tray_id: 5 board_type: "P150" }
      board { tray_id: 6 board_type: "P150" }
      board { tray_id: 7 board_type: "P150" }
      board { tray_id: 8 board_type: "P150" }
    }
    # Internal mesh connections within each loudbox
    port_type_connections {
      key: "QSFP_DD"
      value {
        # Vertical connections between lower half (1-4) and upper half (5-8)
        connections { port_a { tray_id: 1 port_id: 2 } port_b { tray_id: 5 port_id: 1 } }
        connections { port_a { tray_id: 2 port_id: 2 } port_b { tray_id: 6 port_id: 1 } }
        connections { port_a { tray_id: 3 port_id: 2 } port_b { tray_id: 7 port_id: 1 } }
        connections { port_a { tray_id: 4 port_id: 2 } port_b { tray_id: 8 port_id: 1 } }

        # Ring 1: lower half (trays 1-4) on ports 3/4
        connections { port_a { tray_id: 1 port_id: 3 } port_b { tray_id: 2 port_id: 4 } }
        connections { port_a { tray_id: 2 port_id: 3 } port_b { tray_id: 3 port_id: 4 } }
        connections { port_a { tray_id: 3 port_id: 3 } port_b { tray_id: 4 port_id: 4 } }
        connections { port_a { tray_id: 4 port_id: 3 } port_b { tray_id: 1 port_id: 4 } }

        # Ring 2: upper half (trays 5-8) on ports 3/4
        connections { port_a { tray_id: 5 port_id: 3 } port_b { tray_id: 6 port_id: 4 } }
        connections { port_a { tray_id: 6 port_id: 3 } port_b { tray_id: 7 port_id: 4 } }
        connections { port_a { tray_id: 7 port_id: 3 } port_b { tray_id: 8 port_id: 4 } }
        connections { port_a { tray_id: 8 port_id: 3 } port_b { tray_id: 5 port_id: 4 } }
      }
    }
  }
}

graph_templates {
  key: "4x_bh_loudbox"
  value {
    children {
      name: "lb-37"
      node_ref { node_descriptor: "P150_LB" }
    }
    children {
      name: "lb-40"
      node_ref { node_descriptor: "P150_LB" }
    }
    children {
      name: "lb-38"
      node_ref { node_descriptor: "P150_LB" }
    }
    children {
      name: "lb-39"
      node_ref { node_descriptor: "P150_LB" }
    }
    # Inter-loudbox connections forming a RING: L1->L2->L3->L4->L1
    # L1=lb-39, L2=lb-37, L3=lb-40, L4=lb-38
    # Pattern: port 2 on trays 5-8 of source LB -> port 1 on trays 1-4 of dest LB
    internal_connections {
      key: "QSFP_DD"
      value {
        # L1 (lb-39) -> L2 (lb-37) connections
        connections {
          port_a { path: ["lb-39"] tray_id: 5 port_id: 2 }
          port_b { path: ["lb-37"] tray_id: 1 port_id: 1 }
        }
        connections {
          port_a { path: ["lb-39"] tray_id: 6 port_id: 2 }
          port_b { path: ["lb-37"] tray_id: 2 port_id: 1 }
        }
        connections {
          port_a { path: ["lb-39"] tray_id: 7 port_id: 2 }
          port_b { path: ["lb-37"] tray_id: 3 port_id: 1 }
        }
        connections {
          port_a { path: ["lb-39"] tray_id: 8 port_id: 2 }
          port_b { path: ["lb-37"] tray_id: 4 port_id: 1 }
        }

        # L2 (lb-37) -> L3 (lb-40) connections
        connections {
          port_a { path: ["lb-37"] tray_id: 5 port_id: 2 }
          port_b { path: ["lb-40"] tray_id: 1 port_id: 1 }
        }
        connections {
          port_a { path: ["lb-37"] tray_id: 6 port_id: 2 }
          port_b { path: ["lb-40"] tray_id: 2 port_id: 1 }
        }
        connections {
          port_a { path: ["lb-37"] tray_id: 7 port_id: 2 }
          port_b { path: ["lb-40"] tray_id: 3 port_id: 1 }
        }
        connections {
          port_a { path: ["lb-37"] tray_id: 8 port_id: 2 }
          port_b { path: ["lb-40"] tray_id: 4 port_id: 1 }
        }

        # L3 (lb-40) -> L4 (lb-38) connections
        connections {
          port_a { path: ["lb-40"] tray_id: 5 port_id: 2 }
          port_b { path: ["lb-38"] tray_id: 1 port_id: 1 }
        }
        connections {
          port_a { path: ["lb-40"] tray_id: 6 port_id: 2 }
          port_b { path: ["lb-38"] tray_id: 2 port_id: 1 }
        }
        connections {
          port_a { path: ["lb-40"] tray_id: 7 port_id: 2 }
          port_b { path: ["lb-38"] tray_id: 3 port_id: 1 }
        }
        connections {
          port_a { path: ["lb-40"] tray_id: 8 port_id: 2 }
          port_b { path: ["lb-38"] tray_id: 4 port_id: 1 }
        }

        # L4 (lb-38) -> L1 (lb-39) connections (completing the ring!)
        connections {
          port_a { path: ["lb-38"] tray_id: 5 port_id: 2 }
          port_b { path: ["lb-39"] tray_id: 1 port_id: 1 }
        }
        connections {
          port_a { path: ["lb-38"] tray_id: 6 port_id: 2 }
          port_b { path: ["lb-39"] tray_id: 2 port_id: 1 }
        }
        connections {
          port_a { path: ["lb-38"] tray_id: 7 port_id: 2 }
          port_b { path: ["lb-39"] tray_id: 3 port_id: 1 }
        }
        connections {
          port_a { path: ["lb-38"] tray_id: 8 port_id: 2 }
          port_b { path: ["lb-39"] tray_id: 4 port_id: 1 }
        }
      }
    }
  }
}

# Root instance mapping to host IDs
# Ring order: L1→L2→L3→L4→L1 = lb-39→lb-37→lb-40→lb-38→lb-39
root_instance {
  template_name: "4x_bh_loudbox"
  child_mappings {
    key: "lb-39"
    value { host_id: 0 }  # L1
  }
  child_mappings {
    key: "lb-37"
    value { host_id: 1 }  # L2
  }
  child_mappings {
    key: "lb-40"
    value { host_id: 2 }  # L3
  }
  child_mappings {
    key: "lb-38"
    value { host_id: 3 }  # L4
  }
}
