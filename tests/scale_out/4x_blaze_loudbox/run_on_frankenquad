#!/bin/bash

# Script to run tests on the frankenquad (4x8 Blaze Loudbox setup)
# Usage: ./run_on_frankenquad <test_path> [additional_pytest_args]

set -e

if [ $# -eq 0 ]; then
    echo "Usage: $0 <test_path> [pytest_args]"
    echo ""
    echo "Example:"
    echo "  $0 tests/ttnn/unit_tests/operations/ccl/blackhole_CI/Sys_eng_smoke_tests/test_ccl_smoke_test_lbx4.py"
    echo ""
    echo "With additional pytest args:"
    echo "  $0 tests/path/to/test.py -k test_specific_function"
    exit 1
fi

# Collect environment variable assignments (VAR=value) from the beginning
ENV_VARS=()
while [[ $# -gt 0 && "$1" =~ ^[A-Za-z_][A-Za-z0-9_]*= ]]; do
    ENV_VARS+=("$1")
    shift
done

if [ $# -eq 0 ]; then
    echo "Error: No command provided after environment variables"
    exit 1
fi

TEST_PATH="$1"
shift
# Keep remaining args in array to preserve quoting

# Configuration for the 4x8 Blaze Loudbox setup
TCP_INTERFACE="enp194s0f1np1"
HOSTS="bh-lb-39,bh-lb-37,bh-lb-40,bh-lb-38"
RANKFILE="tests/scale_out/4x_blaze_loudbox/rankfile/4x8.txt"
RANK_BINDING="tests/scale_out/4x_blaze_loudbox/rank_bindings/4x8.yaml"
LOG_FILE="/tmp/lbx4_debug.log"

echo "========================================"
echo "Running test on frankenquad"
echo "========================================"
if [ ${#ENV_VARS[@]} -gt 0 ]; then
    echo "Environment: ${ENV_VARS[*]} FORCE_GALAXY_FABRIC_MODE=1"
fi
echo "Command: $TEST_PATH"
echo "Hosts: $HOSTS"
echo "Output log: $LOG_FILE"
if [ $# -gt 0 ]; then
    echo "Additional args: $*"
fi
echo "========================================"
echo ""

tt-run \
  --tcp-interface $TCP_INTERFACE \
  --hosts $HOSTS \
  --mpi-args "--map-by rankfile:file=$RANKFILE" \
  --rank-binding $RANK_BINDING \
  env "${ENV_VARS[@]}" FORCE_GALAXY_FABRIC_MODE=1 "$TEST_PATH" "$@" 2>&1 | tee $LOG_FILE

EXIT_CODE=${PIPESTATUS[0]}

echo ""
echo "========================================"
if [ $EXIT_CODE -eq 0 ]; then
    echo "Test completed successfully!"
else
    echo "Test failed with exit code: $EXIT_CODE"
fi
echo "Full output saved to: $LOG_FILE"
echo "========================================"

exit $EXIT_CODE
