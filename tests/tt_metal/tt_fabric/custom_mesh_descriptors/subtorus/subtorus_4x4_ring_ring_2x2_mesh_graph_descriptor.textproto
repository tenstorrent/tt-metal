# --- Mesh Descriptors ------------------------------------------------------
# Subtorus quad-galaxy mock: 4x4 RING+RING torus spanning 2x2 host ranks (2x2 slice per rank, 16 ASICs).

mesh_descriptors {
  name: "M0"
  arch: BLACKHOLE
  device_topology { dims: [ 4, 4 ] dim_types: [ RING, RING ] }
  host_topology   { dims: [ 2, 2 ] }
  channels { count: 2 policy: RELAXED }
}

# --- Instantiation ----------------------------------------------------------
top_level_instance { mesh { mesh_descriptor: "M0" mesh_id: 0 } }

pinnings {
  logical_fabric_node_id {
    mesh_id: 0
    chip_id: 3
  }
  physical_asic_position {
    tray_id: 4
    asic_location: 2
  }
}
pinnings {
  logical_fabric_node_id {
    mesh_id: 0
    chip_id: 12
  }
  physical_asic_position {
    tray_id: 1
    asic_location: 2
  }
}
