# --- Mesh Descriptors ------------------------------------------------------
# Subtorus quad-galaxy mock: connected 2x4 pair plus disjoint 4x4 pair in one fabric graph.

mesh_descriptors {
  name: "M_2x4"
  arch: BLACKHOLE
  device_topology { dims: [ 2, 4 ] dim_types: [ RING, RING ] }
  host_topology   { dims: [ 1, 1 ] }
  channels { count: 2 policy: RELAXED }
}

mesh_descriptors {
  name: "M_4x4"
  arch: BLACKHOLE
  device_topology { dims: [ 4, 4 ] dim_types: [ RING, RING ] }
  host_topology   { dims: [ 1, 1 ] }
  channels { count: 2 policy: RELAXED }
}

# --- Graph Descriptors -----------------------------------------------------
graph_descriptors {
  name: "G0"
  type: "FABRIC"
  # Connected 2x4 pipeline (mesh ids 0-1).
  instances { mesh { mesh_descriptor: "M_2x4" mesh_id: 0 } }
  instances { mesh { mesh_descriptor: "M_2x4" mesh_id: 1 } }
  # Disjoint 4x4 pair (mesh ids 2-3, no inter-mesh links).
  instances { mesh { mesh_descriptor: "M_4x4" mesh_id: 2 } }
  instances { mesh { mesh_descriptor: "M_4x4" mesh_id: 3 } }

  connections {
    nodes { mesh { mesh_descriptor: "M_2x4" mesh_id: 0 } }
    nodes { mesh { mesh_descriptor: "M_2x4" mesh_id: 1 } }
    channels { count: 8 policy: RELAXED }
    assign_z_direction: true
  }
}

# --- Instantiation ----------------------------------------------------------
top_level_instance { graph { graph_descriptor: "G0" graph_id: 0 } }
