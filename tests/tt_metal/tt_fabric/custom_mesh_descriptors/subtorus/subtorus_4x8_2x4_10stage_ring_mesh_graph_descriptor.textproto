# --- Meshes ---------------------------------------------------------------
# Subtorus quad-galaxy mock: heterogeneous 10-stage ring, 128 ASICs total.
# - 2 stages: single-host 4x8 RING+RING subtorus slices (32 ASICs each)
# - 8 stages: single-host 4x2 RING+LINE tray-pair slices (8 ASICs each; pipeline orientation)
#
# Ring order (mesh ids 0..9, closing 9 -> 0):
#   4x8, 4x2, 4x2, 4x2, 4x2, 4x2, 4x2, 4x2, 4x2, 4x8
#
# Homogeneous 4x2->4x2 hops use NESW (no assign_z_direction) with alternating 8/12 channels,
# matching fabric_cpu_only_blitz_single_pod_mesh_graph_descriptor. assign_z_direction is only set on heterogeneous 4x8<->4x2 hops
# so middle 4x2 stages can connect to both neighbors without exhausting per-chip Z ports.

mesh_descriptors {
  name: "M_4x8"
  arch: BLACKHOLE
  device_topology { dims: [ 4, 8 ] dim_types: [ RING, RING ] }
  host_topology   { dims: [ 1, 1 ] }
  channels { count: 2 policy: RELAXED }
}

mesh_descriptors {
  name: "M_4x2"
  arch: BLACKHOLE
  device_topology { dims: [ 4, 2 ] dim_types: [ RING, LINE ] }
  host_topology   { dims: [ 1, 1 ] }
  channels { count: 2 policy: RELAXED }
}

graph_descriptors {
  name: "G0"
  type: "FABRIC"
  instances { mesh { mesh_descriptor: "M_4x8" mesh_id: 0 } }
  instances { mesh { mesh_descriptor: "M_4x2" mesh_id: 1 } }
  instances { mesh { mesh_descriptor: "M_4x2" mesh_id: 2 } }
  instances { mesh { mesh_descriptor: "M_4x2" mesh_id: 3 } }
  instances { mesh { mesh_descriptor: "M_4x2" mesh_id: 4 } }
  instances { mesh { mesh_descriptor: "M_4x2" mesh_id: 5 } }
  instances { mesh { mesh_descriptor: "M_4x2" mesh_id: 6 } }
  instances { mesh { mesh_descriptor: "M_4x2" mesh_id: 7 } }
  instances { mesh { mesh_descriptor: "M_4x2" mesh_id: 8 } }
  instances { mesh { mesh_descriptor: "M_4x8" mesh_id: 9 } }

  connections {
    nodes { mesh { mesh_descriptor: "M_4x8" mesh_id: 0 } }
    nodes { mesh { mesh_descriptor: "M_4x2" mesh_id: 1 } }
    channels { count: 8 policy: RELAXED }
    assign_z_direction: true
  }
  connections {
    nodes { mesh { mesh_descriptor: "M_4x2" mesh_id: 1 } }
    nodes { mesh { mesh_descriptor: "M_4x2" mesh_id: 2 } }
    channels { count: 8 policy: RELAXED }
  }
  connections {
    nodes { mesh { mesh_descriptor: "M_4x2" mesh_id: 2 } }
    nodes { mesh { mesh_descriptor: "M_4x2" mesh_id: 3 } }
    channels { count: 12 policy: RELAXED }
  }
  connections {
    nodes { mesh { mesh_descriptor: "M_4x2" mesh_id: 3 } }
    nodes { mesh { mesh_descriptor: "M_4x2" mesh_id: 4 } }
    channels { count: 8 policy: RELAXED }
  }
  connections {
    nodes { mesh { mesh_descriptor: "M_4x2" mesh_id: 4 } }
    nodes { mesh { mesh_descriptor: "M_4x2" mesh_id: 5 } }
    channels { count: 12 policy: RELAXED }
  }
  connections {
    nodes { mesh { mesh_descriptor: "M_4x2" mesh_id: 5 } }
    nodes { mesh { mesh_descriptor: "M_4x2" mesh_id: 6 } }
    channels { count: 8 policy: RELAXED }
  }
  connections {
    nodes { mesh { mesh_descriptor: "M_4x2" mesh_id: 6 } }
    nodes { mesh { mesh_descriptor: "M_4x2" mesh_id: 7 } }
    channels { count: 12 policy: RELAXED }
  }
  connections {
    nodes { mesh { mesh_descriptor: "M_4x2" mesh_id: 7 } }
    nodes { mesh { mesh_descriptor: "M_4x2" mesh_id: 8 } }
    channels { count: 8 policy: RELAXED }
  }
  connections {
    nodes { mesh { mesh_descriptor: "M_4x2" mesh_id: 8 } }
    nodes { mesh { mesh_descriptor: "M_4x8" mesh_id: 9 } }
    channels { count: 8 policy: RELAXED }
    assign_z_direction: true
  }
  connections {
    nodes { mesh { mesh_descriptor: "M_4x8" mesh_id: 9 } }
    nodes { mesh { mesh_descriptor: "M_4x8" mesh_id: 0 } }
    channels { count: 8 policy: RELAXED }
    assign_z_direction: true
  }
}

# --- Instantiation ----------------------------------------------------------
top_level_instance { graph { graph_descriptor: "G0" graph_id: 0 } }
