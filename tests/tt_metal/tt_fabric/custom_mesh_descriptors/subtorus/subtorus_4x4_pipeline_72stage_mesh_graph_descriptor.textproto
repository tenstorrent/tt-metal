# --- Meshes ---------------------------------------------------------------
# CPU-only test copy: subtorus 72-stage 4x4 pipeline (ring). 72 stages x 16 chips = 1152 chips,
# an exact fit for SC36 (36 hosts x 32 chips = 1152) -- i.e. 100% device utilization.
# Every stage is a 4x4 torus split across 2 host ranks (2x4 + 2x4). Modeled after
# subtorus_4x4_pipeline_32stage_mesh_graph_descriptor.textproto (SC16, 32-stage).

mesh_descriptors {
  name: "M0"
  arch: BLACKHOLE
  device_topology { dims: [ 4, 4 ] dim_types: [ RING, RING ] }
  host_topology   { dims: [ 2, 1 ] }
  channels { count: 2 policy: STRICT }
}

graph_descriptors {
  name: "G0"
  type: "FABRIC"
