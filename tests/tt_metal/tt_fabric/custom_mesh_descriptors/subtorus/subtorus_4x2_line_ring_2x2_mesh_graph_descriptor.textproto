# --- Mesh Descriptors ------------------------------------------------------
# Subtorus quad-galaxy mock: 4x2 LINE+RING torus spanning 2x1 host ranks (2x2 slice per rank, 8 ASICs).

mesh_descriptors {
  name: "M0"
  arch: BLACKHOLE
  device_topology { dims: [ 4, 2 ] dim_types: [ LINE, RING ] }
  host_topology   { dims: [ 2, 1 ] }
  channels { count: 2 policy: RELAXED }
}

# --- Instantiation ----------------------------------------------------------
top_level_instance { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
