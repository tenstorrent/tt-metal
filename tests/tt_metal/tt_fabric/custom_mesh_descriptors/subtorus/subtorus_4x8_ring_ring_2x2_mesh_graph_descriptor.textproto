# --- Mesh Descriptors ------------------------------------------------------
# Subtorus quad-galaxy mock: 4x8 RING+RING torus spanning 2x2 host ranks (2x4 slice per rank, 32 ASICs).

mesh_descriptors {
  name: "M0"
  arch: BLACKHOLE
  device_topology { dims: [ 4, 8 ] dim_types: [ RING, RING ] }
  host_topology   { dims: [ 2, 2 ] }
  channels { count: 2 policy: RELAXED }
}

# --- Instantiation ----------------------------------------------------------
top_level_instance { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
