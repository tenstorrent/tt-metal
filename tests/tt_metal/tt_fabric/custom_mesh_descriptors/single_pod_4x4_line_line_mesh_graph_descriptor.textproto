# Single-pod bring-up: one logical 4x4 LINE+LINE mesh (16 ASICs) on host_topology [1,1].
# Used to verify PGD matching prefers single-host 4x4_Mesh over cross-host 4x4_SplitHost when both fit.

mesh_descriptors {
  name: "M0"
  arch: BLACKHOLE
  device_topology { dims: [ 4, 4 ] dim_types: [ LINE, LINE ] }
  host_topology   { dims: [ 1, 1 ] }
  channels { count: 2 policy: RELAXED }
}

top_level_instance { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
