# --- Meshes ---------------------------------------------------------------
# NEGATIVE-TEST descriptor: engineered assign_z conflict.
# Four 1x2 meshes wired in a 2x2 grid (same layout as t3k_1x2), one per N300 board:
#     mesh0 - mesh1
#       |       |
#     mesh2 - mesh3
# Mesh 0's right-hand chip borders BOTH mesh 1 (horizontal) and mesh 2 (vertical). Both of those boundaries
# are marked assign_z_direction, so that one chip is asked to place Z toward two different neighbor meshes.
# It has a single Z lane, so the second boundary cannot place any channel on Z and, being Z-only, resolves
# zero routers -> control-plane init must fail. Driven by a hard rank binding (TT_VISIBLE_DEVICES 0..3) so the
# placement is deterministic and does not depend on the topology mapper. Used by MultiHost.T3KAssignZConflictFatal.

mesh_descriptors {
  name: "M0"
  arch: WORMHOLE_B0
  device_topology { dims: [ 1, 2 ] }
  host_topology   { dims: [ 1, 1 ] }
  channels { count: 2 policy: RELAXED }
}

# --- Graphs ---------------------------------------------------------------

graph_descriptors {
  name: "G0"
  type: "FABRIC"
  instances { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
  instances { mesh { mesh_descriptor: "M0" mesh_id: 1 } }
  instances { mesh { mesh_descriptor: "M0" mesh_id: 2 } }
  instances { mesh { mesh_descriptor: "M0" mesh_id: 3 } }

  # mesh 0 <-> mesh 1 (horizontal) : assign_z
  connections {
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 1 } }
    channels { count: 2 }
    assign_z_direction: true
  }
  # mesh 2 <-> mesh 3 (horizontal)
  connections {
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 2 } }
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 3 } }
    channels { count: 2 }
  }

  # mesh 0 <-> mesh 2 (vertical) : assign_z  (CONFLICT -- shares mesh 0's bridge chip Z lane with 0<->1)
  connections {
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 2 } }
    channels { count: 2 }
    assign_z_direction: true
  }
  # mesh 1 <-> mesh 3 (vertical)
  connections {
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 1 } }
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 3 } }
    channels { count: 2 }
  }
}

# --- Instantiation ----------------------------------------------------------
top_level_instance { graph { graph_descriptor: "G0" graph_id: 0 } }
