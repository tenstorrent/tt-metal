# --- Mesh Descriptors ------------------------------------------------------
# 32x4 quad-Blackhole-galaxy mesh spanning 8x2 hosts (16 processes, each owns a 4x2 slice)

mesh_descriptors {
  name: "M0"
  arch: BLACKHOLE
  device_topology { dims: [ 32, 4 ] dim_types: [ LINE, LINE ] }
  host_topology   { dims: [ 8, 2 ] }
  channels { count: 2 policy: RELAXED }
}

# --- Instantiation ----------------------------------------------------------
top_level_instance { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
