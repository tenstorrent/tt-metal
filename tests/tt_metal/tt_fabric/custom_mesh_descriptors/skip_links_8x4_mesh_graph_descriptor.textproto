# Test descriptor: single 8x4 BLACKHOLE torus with a dim-0 skip-link pattern.
# Skip links: dim=0 (length 8), start=2, step=4 -> block [2,5] (the wrapping block is dropped under
# the LINE row axis), replicated across all 4 columns. Used by MeshGraphDescriptorTests.SkipLinks8x4.
mesh_descriptors {
  name: "M0"
  arch: BLACKHOLE
  device_topology { dims: [8, 4] dim_types: [LINE, RING] }
  host_topology   { dims: [1, 1] }
  channels { count: 2 }
  skip_links { dim_idx: 0  pattern { start: 2  step: 4 } }
}
top_level_instance { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
