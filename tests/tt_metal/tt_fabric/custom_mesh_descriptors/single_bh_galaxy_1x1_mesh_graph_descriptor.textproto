# --- Mesh Descriptors ------------------------------------------------------
# 4x8 Blackhole galaxy mesh spanning 4x8 hosts (32 processes, each owns a 1x1 slice)

mesh_descriptors {
  name: "M0"
  arch: BLACKHOLE
  device_topology { dims: [ 4, 8 ] }
  host_topology   { dims: [ 4, 8 ] }
  channels { count: 2 policy: RELAXED }
}

# --- Instantiation ----------------------------------------------------------
top_level_instance { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
