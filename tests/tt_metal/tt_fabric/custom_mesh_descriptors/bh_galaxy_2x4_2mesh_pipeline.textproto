# --- Meshes ---------------------------------------------------------------
# 2-stage pipeline of 2x4 meshes (used for PGD matching tests where
# the PGD provides 2 non-overlapping 4x2_Mesh placements per single BH galaxy).

mesh_descriptors {
  name: "MESH"
  arch: BLACKHOLE
  device_topology { dims: [ 2, 4 ] }
  host_topology   { dims: [ 1, 1 ] }
  channels {
    count: 2
    policy: RELAXED
  }
}
graph_descriptors {
  name: "G0"
  type: "FABRIC"
  instances { mesh { mesh_descriptor: "MESH" mesh_id: 0 } }
  instances { mesh { mesh_descriptor: "MESH" mesh_id: 1 } }

  connections {
    nodes { mesh { mesh_descriptor: "MESH" mesh_id: 0 } }
    nodes { mesh { mesh_descriptor: "MESH" mesh_id: 1 } }
    channels { count: 8 policy: RELAXED }
  }
}
# --- Instantiation ----------------------------------------------------------
top_level_instance { graph { graph_descriptor: "G0" graph_id: 0 } }
