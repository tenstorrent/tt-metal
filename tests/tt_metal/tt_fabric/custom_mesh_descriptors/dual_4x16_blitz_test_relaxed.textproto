# --- Mesh Descriptors ------------------------------------------------------
# Relaxed copy of dual_4x16_blitz_test.textproto used to CAPTURE Finding A without the
# STRICT-policy MPI deadlock (see tt_metal/fabric/intermesh_dual_galaxy_asymmetry_findings.md,
# "Test cases to guard this" #2). The only difference from dual_4x16_blitz_test.textproto is the
# M0<->M1 connection policy: RELAXED instead of STRICT.
#
# Why a relaxed copy is needed: the M0<->M1 boundary (2 cables x 2 channels, meshes split across
# hosts) is exactly the shape that trips Finding A (rank-divergent resolved count: 3 on the M1
# ranks, 4 on rank 0). Under STRICT policy the per-mesh-pair validation TT_THROWs on the M1 ranks
# only DURING control-plane init, before any test body runs -> the surviving ranks block at the next
# MPI collective -> hard deadlock (the process hangs, so no assertion can ever observe the bug).
# Under RELAXED policy the same under-resolve only warns, so control-plane init COMPLETES on every
# rank; the cross-rank consistency helper then runs and fails cleanly (min=3 vs max=4) instead of
# hanging.

mesh_descriptors {
  name: "M0"
  arch: BLACKHOLE
  device_topology { dims: [ 4, 16 ] dim_types: [ RING, LINE ] }
  host_topology   { dims: [ 1, 8 ] }
  channels { count: 2 policy: RELAXED }
}

mesh_descriptors {
  name: "M1"
  arch: BLACKHOLE
  device_topology { dims: [ 4, 16 ] dim_types: [ RING, LINE ] }
  host_topology   { dims: [ 2, 16 ] }
  channels { count: 2 policy: RELAXED }
}

# --- Graph (two meshes + intermesh links) ----------------------------------
graph_descriptors {
  name: "G0"
  type: "FABRIC"
  instances { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
  instances { mesh { mesh_descriptor: "M1" mesh_id: 1 } }

  # Same 4 physical inter-mesh links as dual_4x16_blitz_test.textproto, but RELAXED so an
  # under-resolve (Finding A miscount) warns instead of hard-fatalling -> init completes on all
  # ranks -> the collective consistency helper can observe the rank-divergent count.
  connections {
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
    nodes { mesh { mesh_descriptor: "M1" mesh_id: 1  } }
    channels { count: 4 policy: RELAXED }
  }
}

# --- Instantiation ----------------------------------------------------------
top_level_instance { graph { graph_descriptor: "G0" graph_id: 0 } }
