# --- Mesh Descriptors ------------------------------------------------------
# 16x4 dual-Blackhole-galaxy mesh spanning 4x2 hosts (8 processes, each owns a 4x2 slice)

mesh_descriptors {
  name: "M0"
  arch: BLACKHOLE
  device_topology { dims: [ 16, 4 ] dim_types: [ LINE, LINE ] }
  host_topology   { dims: [ 4, 2 ] }
  channels { count: 2 policy: RELAXED }
}

# --- Instantiation ----------------------------------------------------------
top_level_instance { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
