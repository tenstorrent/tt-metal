# --- Meshes ---------------------------------------------------------------
# 2x2 T3K mesh WITHOUT assign_z_direction - tests Z-direction fallback when NESW ports run out.
# Same structure as t3k_2x2_assign_z_direction but channels.count: 4 without assign_z_direction
# triggers fallback to Z ports when NESW capacity is exhausted.

mesh_descriptors {
  name: "M0"
  arch: BLACKHOLE
  device_topology { dims: [ 2, 2 ] }
  host_topology   { dims: [ 1, 1 ] }
  channels {
    count: 2
    policy: RELAXED
  }
}

# --- Graphs ---------------------------------------------------------------

graph_descriptors {
  name: "G0"
  type: "FABRIC"
  instances { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
  instances { mesh { mesh_descriptor: "M0" mesh_id: 1 } }

  connections {
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
    nodes { mesh { mesh_descriptor: "M0" mesh_id: 1 } }
    channels { count: 4 }
    # assign_z_direction not set - Z fallback will be used when NESW runs out
  }
}

# --- Instantiation ----------------------------------------------------------
top_level_instance { graph { graph_descriptor: "G0" graph_id: 0 } }
