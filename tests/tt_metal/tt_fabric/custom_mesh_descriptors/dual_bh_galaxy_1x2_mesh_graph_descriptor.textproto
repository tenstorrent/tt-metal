# --- Mesh Descriptors ------------------------------------------------------
# 8x8 dual-Blackhole-galaxy mesh spanning 8x4 hosts (32 processes, each owns a 1x2 slice)

mesh_descriptors {
  name: "M0"
  arch: BLACKHOLE
  device_topology { dims: [ 8, 8 ] dim_types: [ LINE, LINE ] }
  host_topology   { dims: [ 8, 4 ] }
  channels { count: 2 policy: RELAXED }
}

# --- Instantiation ----------------------------------------------------------
top_level_instance { mesh { mesh_descriptor: "M0" mesh_id: 0 } }
