    { id: 4 location { asic_location: ASIC_LOCATION_5 tray_id: TRAY_3 } },
    { id: 5 location { asic_location: ASIC_LOCATION_6 tray_id: TRAY_3 } },
    { id: 6 location { asic_location: ASIC_LOCATION_7 tray_id: TRAY_3 } },
    { id: 7 location { asic_location: ASIC_LOCATION_8 tray_id: TRAY_3 } }
