# Blackhole Galaxy Rev A/B physical groupings (new PGD syntax).
# Trays are custom_type TRAY_1..TRAY_4 with location { asic_location tray_id }.
# HALFTRAY_1/HALFTRAY_2 use diagonal half-pod trays {1,3} and {2,4}.
# Selected by generate_rank_bindings for Blackhole Galaxy when PSD is not Rev C.
# Tray 1: top-left corner is ASIC_LOCATION_1
groupings {
  name: "tray_1"
  custom_type: "TRAY_1"
  instances: [
    { id: 0 location { asic_location: ASIC_LOCATION_5 tray_id: TRAY_1 } },
    { id: 1 location { asic_location: ASIC_LOCATION_6 tray_id: TRAY_1 } },
    { id: 2 location { asic_location: ASIC_LOCATION_7 tray_id: TRAY_1 } },
    { id: 3 location { asic_location: ASIC_LOCATION_8 tray_id: TRAY_1 } },
    { id: 4 location { asic_location: ASIC_LOCATION_1 tray_id: TRAY_1 } },
    { id: 5 location { asic_location: ASIC_LOCATION_2 tray_id: TRAY_1 } },
    { id: 6 location { asic_location: ASIC_LOCATION_3 tray_id: TRAY_1 } },
    { id: 7 location { asic_location: ASIC_LOCATION_4 tray_id: TRAY_1 } }
  ]
  row_major_mesh {
    dims: [2, 4]
  }
}

# Tray 2: bottom-left corner is ASIC_LOCATION_1
groupings {
  name: "tray_2"
  custom_type: "TRAY_2"
  instances: [
    { id: 0 location { asic_location: ASIC_LOCATION_8 tray_id: TRAY_2 } },
    { id: 1 location { asic_location: ASIC_LOCATION_7 tray_id: TRAY_2 } },
    { id: 2 location { asic_location: ASIC_LOCATION_6 tray_id: TRAY_2 } },
    { id: 3 location { asic_location: ASIC_LOCATION_5 tray_id: TRAY_2 } },
    { id: 4 location { asic_location: ASIC_LOCATION_4 tray_id: TRAY_2 } },
    { id: 5 location { asic_location: ASIC_LOCATION_3 tray_id: TRAY_2 } },
    { id: 6 location { asic_location: ASIC_LOCATION_2 tray_id: TRAY_2 } },
    { id: 7 location { asic_location: ASIC_LOCATION_1 tray_id: TRAY_2 } }
  ]
  row_major_mesh {
    dims: [2, 4]
  }
}

# Tray 3: top-right corner is ASIC_LOCATION_1
