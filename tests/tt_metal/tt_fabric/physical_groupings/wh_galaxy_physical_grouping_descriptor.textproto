    { id: 0 grouping_ref { custom_type: "tray_2" } },
    { id: 1 grouping_ref { custom_type: "tray_4" } },
    { id: 2 grouping_ref { custom_type: "tray_1" } },
    { id: 3 grouping_ref { custom_type: "tray_3" } }
  ]
  row_major_mesh {
    dims: [2, 2]
  }
}

