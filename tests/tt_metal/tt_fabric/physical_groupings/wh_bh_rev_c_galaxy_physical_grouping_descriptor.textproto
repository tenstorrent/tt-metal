# Wormhole Galaxy + Blackhole Galaxy Rev C physical groupings (new PGD syntax).
# Trays use custom_type tray_1..tray_4 with location { asic_location tray_id }.
# WH and BH Rev C share galaxy_hosts and tray orientations.
# BH Rev C adds HALFTRAY_1/HALFTRAY_2 quadrant slices and generic TRAY cross-tray meshes.
# Selected for Wormhole Galaxy and for Blackhole Galaxy when PSD reports is_bh_galaxy_rev_c().

# Tray 1: top-left corner is ASIC_LOCATION_1
groupings {
  name: "tray_1"
  custom_type: "tray_1"
  instances: [
    { id: 0 location { asic_location: ASIC_LOCATION_5 tray_id: TRAY_1 } },
    { id: 1 location { asic_location: ASIC_LOCATION_6 tray_id: TRAY_1 } },
    { id: 2 location { asic_location: ASIC_LOCATION_7 tray_id: TRAY_1 } },
    { id: 3 location { asic_location: ASIC_LOCATION_8 tray_id: TRAY_1 } },
    { id: 4 location { asic_location: ASIC_LOCATION_1 tray_id: TRAY_1 } },
    { id: 5 location { asic_location: ASIC_LOCATION_2 tray_id: TRAY_1 } },
    { id: 6 location { asic_location: ASIC_LOCATION_3 tray_id: TRAY_1 } },
    { id: 7 location { asic_location: ASIC_LOCATION_4 tray_id: TRAY_1 } }
  ]
  row_major_mesh {
    dims: [2, 4]
  }
}

# Tray 2: top-right corner is ASIC_LOCATION_1
groupings {
  name: "tray_2"
  custom_type: "tray_2"
  instances: [
    { id: 0 location { asic_location: ASIC_LOCATION_1 tray_id: TRAY_2 } },
    { id: 1 location { asic_location: ASIC_LOCATION_2 tray_id: TRAY_2 } },
    { id: 2 location { asic_location: ASIC_LOCATION_3 tray_id: TRAY_2 } },
    { id: 3 location { asic_location: ASIC_LOCATION_4 tray_id: TRAY_2 } },
    { id: 4 location { asic_location: ASIC_LOCATION_5 tray_id: TRAY_2 } },
    { id: 5 location { asic_location: ASIC_LOCATION_6 tray_id: TRAY_2 } },
    { id: 6 location { asic_location: ASIC_LOCATION_7 tray_id: TRAY_2 } },
    { id: 7 location { asic_location: ASIC_LOCATION_8 tray_id: TRAY_2 } }
  ]
  row_major_mesh {
    dims: [2, 4]
  }
}

# Tray 3: bottom-left corner is ASIC_LOCATION_1
groupings {
  name: "tray_3"
  custom_type: "tray_3"
  instances: [
    { id: 0 location { asic_location: ASIC_LOCATION_8 tray_id: TRAY_3 } },
    { id: 1 location { asic_location: ASIC_LOCATION_7 tray_id: TRAY_3 } },
    { id: 2 location { asic_location: ASIC_LOCATION_6 tray_id: TRAY_3 } },
    { id: 3 location { asic_location: ASIC_LOCATION_5 tray_id: TRAY_3 } },
    { id: 4 location { asic_location: ASIC_LOCATION_4 tray_id: TRAY_3 } },
    { id: 5 location { asic_location: ASIC_LOCATION_3 tray_id: TRAY_3 } },
    { id: 6 location { asic_location: ASIC_LOCATION_2 tray_id: TRAY_3 } },
    { id: 7 location { asic_location: ASIC_LOCATION_1 tray_id: TRAY_3 } }
  ]
  row_major_mesh {
    dims: [2, 4]
  }
}

# Tray 4: bottom-right corner is ASIC_LOCATION_1
groupings {
  name: "tray_4"
  custom_type: "tray_4"
  instances: [
    { id: 0 location { asic_location: ASIC_LOCATION_4 tray_id: TRAY_4 } },
    { id: 1 location { asic_location: ASIC_LOCATION_3 tray_id: TRAY_4 } },
    { id: 2 location { asic_location: ASIC_LOCATION_2 tray_id: TRAY_4 } },
    { id: 3 location { asic_location: ASIC_LOCATION_1 tray_id: TRAY_4 } },
    { id: 4 location { asic_location: ASIC_LOCATION_8 tray_id: TRAY_4 } },
    { id: 5 location { asic_location: ASIC_LOCATION_7 tray_id: TRAY_4 } },
    { id: 6 location { asic_location: ASIC_LOCATION_6 tray_id: TRAY_4 } },
    { id: 7 location { asic_location: ASIC_LOCATION_5 tray_id: TRAY_4 } }
  ]
  row_major_mesh {
    dims: [2, 4]
  }
}

# HOSTS: 4 trays
groupings {
  name: "galaxy_hosts"
  preset_type: HOSTS
  instances: [
    { id: 0 grouping_ref { custom_type: "tray_2" } },
    { id: 1 grouping_ref { custom_type: "tray_4" } },
    { id: 2 grouping_ref { custom_type: "tray_1" } },
    { id: 3 grouping_ref { custom_type: "tray_3" } }
  ]
  row_major_mesh {
    dims: [2, 2]
  }
}

