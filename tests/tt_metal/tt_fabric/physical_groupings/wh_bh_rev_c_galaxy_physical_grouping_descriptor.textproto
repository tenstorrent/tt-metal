# Half-trays (2x2 quadrants). Rev C groups them so each valid 4x2 mesh pair straddles
# the two groups: HALFTRAY_1 = trays 1 & 3, HALFTRAY_2 = trays 2 & 4.
# HALFTRAY_1: tray 1 quadrants
groupings {
  name: "halftray_2x2_group_1"
  custom_type: "HALFTRAY_1"
  instances: [
    { id: 0 location { asic_location: ASIC_LOCATION_5 tray_id: TRAY_1 } },
    { id: 1 location { asic_location: ASIC_LOCATION_6 tray_id: TRAY_1 } },
    { id: 2 location { asic_location: ASIC_LOCATION_1 tray_id: TRAY_1 } },
    { id: 3 location { asic_location: ASIC_LOCATION_2 tray_id: TRAY_1 } }
  ]
  row_major_mesh {
    dims: [2, 2]
  }
}
groupings {
  name: "halftray_2x2_group_1"
  custom_type: "HALFTRAY_1"
  instances: [
    { id: 0 location { asic_location: ASIC_LOCATION_7 tray_id: TRAY_1 } },
    { id: 1 location { asic_location: ASIC_LOCATION_8 tray_id: TRAY_1 } },
    { id: 2 location { asic_location: ASIC_LOCATION_3 tray_id: TRAY_1 } },
    { id: 3 location { asic_location: ASIC_LOCATION_4 tray_id: TRAY_1 } }
  ]
  row_major_mesh {
    dims: [2, 2]
  }
}
