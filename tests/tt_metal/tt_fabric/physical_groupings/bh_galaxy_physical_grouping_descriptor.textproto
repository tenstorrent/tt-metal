  name: "4x4_Mesh BH"
  preset_type: MESH
  instances: [
    { id: 0 grouping_ref { preset_type: TRAY_4 } },
    { id: 1 grouping_ref { preset_type: TRAY_2 } }
  ]
  row_major_mesh {
    dims: [2, 1]
  }
}

# MESH: 2 trays (16 ASICs)
groupings {
  name: "2x8_Mesh BH"
  preset_type: MESH
  instances: [
    { id: 0 grouping_ref { preset_type: TRAY_1 } },
    { id: 1 grouping_ref { preset_type: TRAY_2 } }
  ]
  row_major_mesh {
    dims: [1, 2]
  }
}

# MESH: 2 trays (16 ASICs)
groupings {
  name: "2x8_Mesh BH"
  preset_type: MESH
  instances: [
    { id: 0 grouping_ref { preset_type: TRAY_3 } },
    { id: 1 grouping_ref { preset_type: TRAY_4 } }
  ]
  row_major_mesh {
    dims: [1, 2]
  }
}


# MESH: 1 host (32 ASICs) - for single galaxy (8x4)
# Note: Single instance grouping, no row_major_mesh needed (only applies to multi-instance groupings)
groupings {
  name: "4x8_Mesh"
  preset_type: MESH
  instances: [
    { id: 0 grouping_ref { preset_type: HOSTS } }
  ]
}

groupings {
  name: "8x8_Mesh"
  preset_type: MESH
  instances: [
    { id: 0 grouping_ref { preset_type: HOSTS } },
    { id: 1 grouping_ref { preset_type: HOSTS } }
  ]
  row_major_mesh {
    dims: [2, 1]
  }
}

groupings {
  name: "4x16_Mesh"
  preset_type: MESH
  instances: [
    { id: 0 grouping_ref { preset_type: HOSTS } },
    { id: 1 grouping_ref { preset_type: HOSTS } }
  ]
  row_major_mesh {
    dims: [1, 2]
  }
}

# MESH: 4 hosts (128 ASICs) arranged in 2x2 grid - for 16x8 quad BH galaxy
groupings {
  name: "8x16_Mesh"
  preset_type: MESH
  instances: [
    { id: 0 grouping_ref { preset_type: HOSTS } },
    { id: 1 grouping_ref { preset_type: HOSTS } },
    { id: 2 grouping_ref { preset_type: HOSTS } },
    { id: 3 grouping_ref { preset_type: HOSTS } }
  ]
  row_major_mesh {
    dims: [2, 2]
  }
}

# MESH: 4 hosts (128 ASICs) arranged in 2x2 grid - for 16x8 quad BH galaxy
groupings {
  name: "4x32_Mesh"
  preset_type: MESH
  instances: [
    { id: 0 grouping_ref { preset_type: HOSTS } },
    { id: 1 grouping_ref { preset_type: HOSTS } },
    { id: 2 grouping_ref { preset_type: HOSTS } },
    { id: 3 grouping_ref { preset_type: HOSTS } }
  ]
