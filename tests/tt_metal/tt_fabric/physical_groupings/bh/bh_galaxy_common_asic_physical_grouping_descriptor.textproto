# Canonical 2x2 MESH candidates, one per explicit 2x2 ASIC grouping.
groupings {
  name: "2x2 Mesh"
  preset_type: MESH
  instances: [
    { id: 0 grouping_ref { custom_type: "ASIC_1256" } }
  ]
}

